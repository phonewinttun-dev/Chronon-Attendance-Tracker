    private async Task LoadGoogleCalendarStatus()
    {
        try
        {
            var status = await Http.GetFromJsonAsync<GoogleCalendarStatusResponse>("api/google-auth/status");
            if (status != null)
            {
                _googleCalendarEnabled = status.IsEnabled;
                _googleCalendarConnected = status.IsConnected;
            }
        }
        catch
        {
            _googleCalendarEnabled = false;
            _googleCalendarConnected = false;
        }
    }

    private bool _showConnectConfirmation = false;

    private void ConnectGoogleCalendar()
    {
        _showConnectConfirmation = true;
    }

    private void CloseConnectConfirmation()
    {
        _showConnectConfirmation = false;
    }

    private void ConfirmConnectGoogleCalendar()
    {
        _showConnectConfirmation = false;
        try
        {
            var redirectUrl = $"{Navigation.BaseUri}calendar";
            var connectUrl = new Uri(Http.BaseAddress!, $"api/google-auth/connect?redirectUrl={Uri.EscapeDataString(redirectUrl)}").ToString();
            Navigation.NavigateTo(connectUrl, forceLoad: true);
        }
        catch (Exception ex)
        {
            _message = $"Failed to initiate connection: {ex.Message}";
            _isError = true;
        }
    }

    private async Task DisconnectGoogleCalendar()
    {
        _isDisconnecting = true;
        try
        {
            var response = await Http.PostAsync("api/google-auth/disconnect", null);
            if (response.IsSuccessStatusCode)
            {
                _message = "Disconnected from Google Calendar successfully.";
                _isError = false;
                await LoadGoogleCalendarStatus();
            }
            else
            {
                _message = "Failed to disconnect from Google Calendar.";
                _isError = true;
            }
        }
        catch (Exception ex)
        {
            _message = $"Error disconnecting: {ex.Message}";
            _isError = true;
        }
        finally
        {
            _isDisconnecting = false;
        }
    }

    private void ToggleSettings()
    {
        _showCalendarSettings = !_showCalendarSettings;
    }

    private string FormatGoogleCalendarTime(DateTime utcTime)
    {
        var localTime = utcTime + MyanmarOffset;
        if (localTime.Minute == 0)
        {
            return localTime.ToString("htt").ToLower();
        }
        return localTime.ToString("h:mmtt").ToLower();
    }

    private string GetDotColorClass(string status)
    {
        return status switch
        {
            "Present" => "bg-emerald-500",
            "Absent" => "bg-destructive",
            "Late" => "bg-amber-500",
            "Cancelled" => "bg-muted-foreground/45",
            "Holiday" => "bg-purple-500",
            _ => "bg-blue-500"
        };
    }

    private class GoogleCalendarStatusResponse
    {
        public bool IsEnabled { get; set; }
        public bool IsConnected { get; set; }
    }
}
