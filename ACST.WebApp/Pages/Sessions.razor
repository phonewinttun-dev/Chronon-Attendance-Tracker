@page "/sessions"
@using ACST.WebApp.Models
@inject HttpClient Http

<PageTitle>Sessions</PageTitle>

<div class="flex justify-between items-center mb-8">
    <h1 class="text-2xl font-bold tracking-tight text-foreground">Class Sessions</h1>
    <button class="bg-primary text-primary-foreground hover:bg-primary/90 px-4 py-2 rounded-md text-sm font-semibold transition-all disabled:opacity-50" @onclick="GenerateSessions" disabled="@_isGenerating">
        @(_isGenerating ? "Generating..." : "Generate Sessions")
    </button>
</div>

@if (!string.IsNullOrEmpty(_message))
{
    <div class="border p-4 rounded-md mb-6 text-sm font-medium @(_isError ? "bg-destructive/10 border-destructive/30 text-destructive" : "bg-emerald-500/10 border-emerald-500/20 text-emerald-500")">
        @_message
    </div>
}

<div class="bg-card border border-border rounded-lg shadow-sm overflow-hidden">
    @if (_isLoading)
    {
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse text-xs animate-pulse">
                <thead>
                    <tr class="border-b border-border bg-muted/50">
                        <th class="px-6 py-3.5 font-semibold text-muted-foreground uppercase tracking-wider">Date</th>
                        <th class="px-6 py-3.5 font-semibold text-muted-foreground uppercase tracking-wider">Module</th>
                        <th class="px-6 py-3.5 font-semibold text-muted-foreground uppercase tracking-wider">Status</th>
                        <th class="px-6 py-3.5 font-semibold text-muted-foreground uppercase tracking-wider">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-border">
                    @for (int i = 0; i < 8; i++)
                    {
                        <tr>
                            <td class="px-6 py-4">
                                <div class="h-3 bg-muted rounded w-20"></div>
                            </td>
                            <td class="px-6 py-4">
                                <div class="h-3 bg-muted rounded w-32"></div>
                            </td>
                            <td class="px-6 py-4">
                                <div class="h-5 bg-muted rounded-full w-16"></div>
                            </td>
                            <td class="px-6 py-4">
                                <div class="flex gap-2">
                                    <div class="h-7 bg-muted rounded w-20"></div>
                                    <div class="h-7 bg-muted rounded w-20"></div>
                                    <div class="h-7 bg-muted rounded w-20"></div>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else if (_sessions == null || !_sessions.Any())
    {
        <div class="p-6 text-muted-foreground text-sm">No class sessions found. Try generating sessions for the current semester.</div>
    }
    else
    {
        <table class="w-full text-left border-collapse text-xs">
            <thead>
                <tr class="border-b border-border bg-muted/50">
                    <th class="px-6 py-3.5 font-semibold text-muted-foreground uppercase tracking-wider">Date</th>
                    <th class="px-6 py-3.5 font-semibold text-muted-foreground uppercase tracking-wider">Module</th>
                    <th class="px-6 py-3.5 font-semibold text-muted-foreground uppercase tracking-wider">Status</th>
                    <th class="px-6 py-3.5 font-semibold text-muted-foreground uppercase tracking-wider">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-border">
                @foreach (var session in _sessions)
                {
                    <tr class="hover:bg-accent/40 transition-colors">
                        <td class="px-6 py-3 font-mono text-foreground">@session.SessionDate.ToString("dd-MM-yyyy")</td>
                        <td class="px-6 py-3 text-foreground">@session.ModuleName</td>
                        <td class="px-6 py-3">
                            <span class="@GetBadgeClass(session.Status)">@session.Status</span>
                        </td>
                        <td class="px-6 py-3">
                            <div class="flex flex-wrap gap-2">
                                @if (DateTime.UtcNow <= session.StartDatetime.AddHours(24))
                                {
                                    @if (session.Status == "Not Marked" || session.Status == "Late")
                                    {
                                        <button class="w-20 bg-emerald-500/10 hover:bg-emerald-500 text-emerald-500 hover:text-white border border-emerald-500/30 py-1 rounded text-xs font-semibold text-center transition-all" @onclick='() => UpdateStatus(session.Id, "Present")'>Present</button>
                                        <button class="w-20 bg-destructive/10 hover:bg-destructive text-destructive hover:text-white border border-destructive/30 py-1 rounded text-xs font-semibold text-center transition-all" @onclick='() => UpdateStatus(session.Id, "Absent")'>Absent</button>
                                    }
                                    <button class="w-20 bg-secondary hover:bg-secondary/80 text-foreground border border-border py-1 rounded text-xs font-semibold text-center transition-all" @onclick="() => OpenEditModal(session)">Edit</button>
                                    <button class="w-20 bg-destructive/10 hover:bg-destructive text-destructive hover:text-white border border-destructive/30 py-1 rounded text-xs font-semibold text-center transition-all" @onclick="() => DeleteSession(session.Id)">Delete</button>
                                }
                                else
                                {
                                    <span class="text-muted-foreground text-xs italic">Locked</span>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

@if (_showEditModal && _editingSession != null)
{
    <div class="fixed inset-0 bg-background/80 backdrop-blur-sm flex items-center justify-center z-50" @onclick="CloseEditModal">
        <div class="bg-card border border-border rounded-lg p-6 max-w-md w-full shadow-lg" @onclick:stopPropagation>
            <!-- Modal Header -->
            <div class="flex justify-between items-start border-b border-border pb-3 mb-4">
                <div>
                    <h3 class="text-base font-bold text-foreground tracking-tight">Edit Session</h3>
                </div>
                <button type="button" class="text-muted-foreground hover:text-foreground font-semibold text-lg" @onclick="CloseEditModal">×</button>
            </div>

            <!-- Modal Content / Form -->
            <div class="space-y-4 mb-6">
                <div>
                    <label class="block text-xs font-semibold text-muted-foreground uppercase tracking-wider mb-1.5">Module</label>
                    <select class="w-full p-2 bg-card border border-input rounded-md text-foreground text-sm focus:outline-none focus:ring-1 focus:ring-ring" @bind="_editModuleId">
                        @if (_modules != null)
                        {
                            @foreach (var mod in _modules)
                            {
                                <option value="@mod.Id">@mod.Name</option>
                            }
                        }
                    </select>
                </div>

                <div>
                    <label class="block text-xs font-semibold text-muted-foreground uppercase tracking-wider mb-1.5">Session Date</label>
                    <DatePicker @bind-Value="_editSessionDate" />
                </div>

                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="block text-xs font-semibold text-muted-foreground uppercase tracking-wider mb-1.5">Start Time</label>
                        <input type="time" class="w-full p-2 bg-card border border-input rounded-md text-foreground text-sm focus:outline-none focus:ring-1 focus:ring-ring font-mono" @bind="_editStartTime" />
                    </div>
                    <div>
                        <label class="block text-xs font-semibold text-muted-foreground uppercase tracking-wider mb-1.5">End Time</label>
                        <input type="time" class="w-full p-2 bg-card border border-input rounded-md text-foreground text-sm focus:outline-none focus:ring-1 focus:ring-ring font-mono" @bind="_editEndTime" />
                    </div>
                </div>

                <div>
                    <label class="block text-xs font-semibold text-muted-foreground uppercase tracking-wider mb-1.5">Status</label>
                    <select class="w-full p-2 bg-card border border-input rounded-md text-foreground text-sm focus:outline-none focus:ring-1 focus:ring-ring" @bind="_editStatus">
                        <option value="Not Marked">Not Marked</option>
                        <option value="Present">Present</option>
                        <option value="Absent">Absent</option>
                        <option value="Cancelled">Cancelled</option>
                        <option value="Holiday">Holiday</option>
                    </select>
                </div>
            </div>

            <!-- Action Buttons -->
            <div class="flex justify-end gap-3">
                <button class="px-4 py-2 border border-input rounded-md text-sm font-medium text-foreground hover:bg-muted transition-colors" @onclick="CloseEditModal">Cancel</button>
                <button class="px-4 py-2 bg-primary text-primary-foreground rounded-md text-sm font-medium hover:bg-primary/90 transition-colors" @onclick="SaveSession" disabled="@_isSaving">
                    @(_isSaving ? "Saving..." : "Save")
                </button>
            </div>
        </div>
    </div>
}

@code {
    private List<ClassSessionDto>? _sessions;
    private bool _isLoading = true;
    private bool _isGenerating = false;
    private string _message = string.Empty;
    private bool _isError = false;

    [SupplyParameterFromQuery]
    public long? SemesterId { get; set; }

    [SupplyParameterFromQuery]
    public string? StartDate { get; set; }

    [SupplyParameterFromQuery]
    public string? EndDate { get; set; }

    [SupplyParameterFromQuery]
    public string? Status { get; set; }

    [SupplyParameterFromQuery]
    public int? DayOfWeek { get; set; }

    protected override async Task OnInitializedAsync()
    {
        await Task.WhenAll(LoadSessions(), LoadModules());
    }

    private async Task LoadSessions()
    {
        _isLoading = true;
        try
        {
            var query = new List<string>();
            if (SemesterId.HasValue) query.Add($"semesterId={SemesterId}");
            if (!string.IsNullOrEmpty(StartDate)) query.Add($"startDate={StartDate}");
            if (!string.IsNullOrEmpty(EndDate)) query.Add($"endDate={EndDate}");
            if (!string.IsNullOrEmpty(Status)) query.Add($"status={Uri.EscapeDataString(Status)}");
            if (DayOfWeek.HasValue) query.Add($"dayOfWeek={DayOfWeek}");

            var queryString = query.Any() ? "?" + string.Join("&", query) : "";
            var result = await Http.GetFromJsonAsync<ApiResult<List<ClassSessionDto>>>($"api/classsessions{queryString}");
            if (result != null && result.IsSuccess)
            {
                _sessions = result.Data;
            }
        }
        catch (Exception ex)
        {
            _message = "Error loading sessions: " + ex.Message;
            _isError = true;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task GenerateSessions()
    {
        _isGenerating = true;
        _message = string.Empty;

        try
        {
            var semestersResult = await Http.GetFromJsonAsync<ApiResult<List<SemesterDto>>>("api/semesters");
            var latestSemester = semestersResult?.Data?.OrderByDescending(s => s.StartDate).FirstOrDefault();

            if (latestSemester == null)
            {
                _message = "No semesters found. Please create a semester first.";
                _isError = true;
                return;
            }

            var request = new { SemesterId = latestSemester.Id };
            var response = await Http.PostAsJsonAsync("api/classsessions/generate", request);
            var result = await response.Content.ReadFromJsonAsync<ApiResult>();

            if (result != null && result.IsSuccess)
            {
                _message = result.Message;
                _isError = false;
                await LoadSessions();
            }
            else
            {
                _message = result?.Message ?? "Unknown error generating sessions.";
                _isError = true;
            }
        }
        catch (Exception ex)
        {
            _message = "Error: " + ex.Message;
            _isError = true;
        }
        finally
        {
            _isGenerating = false;
        }
    }

    private async Task UpdateStatus(long id, string status)
    {
        try
        {
            var request = new { Status = status };
            var response = await Http.PatchAsJsonAsync($"api/classsessions/{id}/status", request);
            if (response.IsSuccessStatusCode)
            {
                await LoadSessions();
            }
        }
        catch
        {
            // Handle error
        }
    }

    private string GetBadgeClass(string status)
    {
        return status switch
        {
            "Present" => "bg-emerald-500/10 text-emerald-500 border border-emerald-500/20 px-2 py-0.5 rounded text-xs font-semibold",
            "Absent" => "bg-destructive/10 text-destructive border border-destructive/20 px-2 py-0.5 rounded text-xs font-semibold",
            "Late" => "bg-amber-500/10 text-amber-500 border border-amber-500/20 px-2 py-0.5 rounded text-xs font-semibold",
            _ => "bg-muted text-muted-foreground border border-border px-2 py-0.5 rounded text-xs font-semibold"
        };
    }

    private List<ModuleDto>? _modules;
    private bool _showEditModal = false;
    private ClassSessionDto? _editingSession;
    private long _editModuleId;
    private DateOnly _editSessionDate;
    private TimeOnly _editStartTime;
    private TimeOnly _editEndTime;
    private string _editStatus = string.Empty;
    private bool _isSaving = false;

    private static readonly TimeSpan MyanmarOffset = TimeSpan.FromHours(6.5);

    private async Task LoadModules()
    {
        try
        {
            var result = await Http.GetFromJsonAsync<ApiResult<List<ModuleDto>>>("api/modules");
            if (result != null && result.IsSuccess)
            {
                _modules = result.Data;
            }
        }
        catch
        {
            // Ignore module loading errors
        }
    }

    private void OpenEditModal(ClassSessionDto session)
    {
        _editingSession = session;
        _editModuleId = session.ModuleId;
        _editSessionDate = session.SessionDate;
        
        var startLocal = session.StartDatetime + MyanmarOffset;
        var endLocal = session.EndDatetime + MyanmarOffset;
        
        _editStartTime = TimeOnly.FromDateTime(startLocal);
        _editEndTime = TimeOnly.FromDateTime(endLocal);
        _editStatus = session.Status;
        
        _showEditModal = true;
    }

    private void CloseEditModal()
    {
        _showEditModal = false;
        _editingSession = null;
    }

    private async Task SaveSession()
    {
        if (_editingSession == null) return;

        _isSaving = true;
        _message = string.Empty;
        try
        {
            var startDateTimeLocal = new DateTime(
                _editSessionDate.Year, _editSessionDate.Month, _editSessionDate.Day,
                _editStartTime.Hour, _editStartTime.Minute, 0);
                
            var endDateTimeLocal = new DateTime(
                _editSessionDate.Year, _editSessionDate.Month, _editSessionDate.Day,
                _editEndTime.Hour, _editEndTime.Minute, 0);

            var startUtc = startDateTimeLocal - MyanmarOffset;
            var endUtc = endDateTimeLocal - MyanmarOffset;

            var request = new
            {
                ModuleId = _editModuleId,
                SessionDate = _editSessionDate,
                StartDatetime = startUtc,
                EndDatetime = endUtc,
                Status = _editStatus
            };

            var response = await Http.PutAsJsonAsync($"api/classsessions/{_editingSession.Id}", request);
            var result = await response.Content.ReadFromJsonAsync<ApiResult>();

            if (result != null && result.IsSuccess)
            {
                _message = "Session updated successfully.";
                _isError = false;
                _showEditModal = false;
                await LoadSessions();
            }
            else
            {
                _message = result?.Message ?? "Failed to update session.";
                _isError = true;
            }
        }
        catch (Exception ex)
        {
            _message = "Error: " + ex.Message;
            _isError = true;
        }
        finally
        {
            _isSaving = false;
        }
    }

    private async Task DeleteSession(long id)
    {
        _message = string.Empty;
        try
        {
            var response = await Http.DeleteAsync($"api/classsessions/{id}");
            var result = await response.Content.ReadFromJsonAsync<ApiResult>();

            if (result != null && result.IsSuccess)
            {
                _message = "Session deleted successfully.";
                _isError = false;
                await LoadSessions();
            }
            else
            {
                _message = result?.Message ?? "Failed to delete session.";
                _isError = true;
            }
        }
        catch (Exception ex)
        {
            _message = "Error: " + ex.Message;
            _isError = true;
        }
    }
}
