@page "/sessions"
@using ACST.WebApp.Models
@inject HttpClient Http

<PageTitle>Sessions</PageTitle>

<div class="flex justify-between items-center mb-8">
    <h1 class="text-3xl font-bold">Class Sessions</h1>
    <button class="bg-primary hover:bg-primary-fixed-dim text-on-primary font-medium px-4 py-2 rounded-md transition-colors disabled:opacity-50" @onclick="GenerateSessions" disabled="@_isGenerating">
        @(_isGenerating ? "Generating..." : "Generate Sessions")
    </button>
</div>

@if (!string.IsNullOrEmpty(_message))
{
    <div class="bg-surface-container border @(_isError ? "border-error text-error" : "border-primary text-primary") p-4 rounded-md mb-6">
        @_message
    </div>
}

<div class="bg-surface-container border border-outline-variant rounded-md shadow-md overflow-hidden">
    @if (_isLoading)
    {
        <div class="p-6 text-on-surface-variant">Loading...</div>
    }
    else if (_sessions == null || !_sessions.Any())
    {
        <div class="p-6 text-on-surface-variant">No class sessions found. Try generating sessions for the current semester.</div>
    }
    else
    {
        <table class="w-full text-left border-collapse">
            <thead>
                <tr class="border-b border-outline-variant bg-surface-variant">
                    <th class="px-6 py-4 text-xs font-semibold text-on-surface-variant uppercase tracking-wider">Date</th>
                    <th class="px-6 py-4 text-xs font-semibold text-on-surface-variant uppercase tracking-wider">Module</th>
                    <th class="px-6 py-4 text-xs font-semibold text-on-surface-variant uppercase tracking-wider">Status</th>
                    <th class="px-6 py-4 text-xs font-semibold text-on-surface-variant uppercase tracking-wider">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-outline-variant">
                @foreach (var session in _sessions)
                {
                    <tr class="hover:bg-surface-variant/50 transition-colors">
                        <td class="px-6 py-4 font-mono">@session.SessionDate.ToString("dd-MM-yyyy")</td>
                        <td class="px-6 py-4">@session.ModuleName</td>
                        <td class="px-6 py-4">
                            <span class="@GetBadgeClass(session.Status)">@session.Status</span>
                        </td>
                        <td class="px-6 py-4">
                            @if (session.Status == "Not Marked" || session.Status == "Late")
                            {
                                <button class="bg-primary/20 text-primary border border-primary px-3 py-1 rounded hover:bg-primary hover:text-on-primary transition-colors text-sm mr-2" @onclick='() => UpdateStatus(session.Id, "Present")'>Present</button>
                                <button class="bg-error/20 text-error border border-error px-3 py-1 rounded hover:bg-error hover:text-on-error transition-colors text-sm" @onclick='() => UpdateStatus(session.Id, "Absent")'>Absent</button>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

@code {
    private List<ClassSessionDto>? _sessions;
    private bool _isLoading = true;
    private bool _isGenerating = false;
    private string _message = string.Empty;
    private bool _isError = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadSessions();
    }

    private async Task LoadSessions()
    {
        _isLoading = true;
        try
        {
            var result = await Http.GetFromJsonAsync<ApiResult<List<ClassSessionDto>>>("api/classsessions");
            if (result != null && result.IsSuccess)
            {
                _sessions = result.Data;
            }
        }
        catch (Exception ex)
        {
            _message = "Error loading sessions: " + ex.Message;
            _isError = true;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task GenerateSessions()
    {
        _isGenerating = true;
        _message = string.Empty;

        try
        {
            var semestersResult = await Http.GetFromJsonAsync<ApiResult<List<SemesterDto>>>("api/semesters");
            var latestSemester = semestersResult?.Data?.OrderByDescending(s => s.StartDate).FirstOrDefault();

            if (latestSemester == null)
            {
                _message = "No semesters found. Please create a semester first.";
                _isError = true;
                return;
            }

            var request = new { SemesterId = latestSemester.Id };
            var response = await Http.PostAsJsonAsync("api/classsessions/generate", request);
            var result = await response.Content.ReadFromJsonAsync<ApiResult>();

            if (result != null && result.IsSuccess)
            {
                _message = result.Message;
                _isError = false;
                await LoadSessions();
            }
            else
            {
                _message = result?.Message ?? "Unknown error generating sessions.";
                _isError = true;
            }
        }
        catch (Exception ex)
        {
            _message = "Error: " + ex.Message;
            _isError = true;
        }
        finally
        {
            _isGenerating = false;
        }
    }

    private async Task UpdateStatus(long id, string status)
    {
        try
        {
            var request = new { Status = status };
            var response = await Http.PatchAsJsonAsync($"api/classsessions/{id}/status", request);
            if (response.IsSuccessStatusCode)
            {
                await LoadSessions();
            }
        }
        catch
        {
            // Handle error
        }
    }

    private string GetBadgeClass(string status)
    {
        return status switch
        {
            "Present" => "bg-primary/20 text-primary border border-primary px-2 py-1 rounded text-xs font-semibold",
            "Absent" => "bg-error/20 text-error border border-error px-2 py-1 rounded text-xs font-semibold",
            "Late" => "bg-secondary/20 text-secondary border border-secondary px-2 py-1 rounded text-xs font-semibold",
            _ => "bg-surface-variant text-on-surface-variant border border-outline px-2 py-1 rounded text-xs font-semibold"
        };
    }
}
