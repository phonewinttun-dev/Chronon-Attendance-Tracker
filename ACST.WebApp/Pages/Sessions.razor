    private bool _showEditModal = false;
    private ClassSessionDto? _editingSession;
    private long _editModuleId;
    private DateOnly _editSessionDate;
    private TimeOnly _editStartTime;
    private TimeOnly _editEndTime;
    private string _editStatus = string.Empty;
    private bool _isSaving = false;

    private static readonly TimeSpan MyanmarOffset = TimeSpan.FromHours(6.5);

    private void OpenEditModal(ClassSessionDto session)
    {
        _editingSession = session;
        _editModuleId = session.ModuleId;
        _editSessionDate = session.SessionDate;
        
        var startLocal = session.StartDatetime + MyanmarOffset;
        var endLocal = session.EndDatetime + MyanmarOffset;
        
        _editStartTime = TimeOnly.FromDateTime(startLocal);
        _editEndTime = TimeOnly.FromDateTime(endLocal);
        _editStatus = session.Status;
        
        _showEditModal = true;
    }

    private void CloseEditModal()
    {
        _showEditModal = false;
        _editingSession = null;
    }

    private async Task SaveSession()
    {
        if (_editingSession == null) return;

        _isSaving = true;
        _message = string.Empty;
        try
        {
            var startDateTimeLocal = new DateTime(
                _editSessionDate.Year, _editSessionDate.Month, _editSessionDate.Day,
                _editStartTime.Hour, _editStartTime.Minute, 0);
                
            var endDateTimeLocal = new DateTime(
                _editSessionDate.Year, _editSessionDate.Month, _editSessionDate.Day,
                _editEndTime.Hour, _editEndTime.Minute, 0);

            var startUtc = startDateTimeLocal - MyanmarOffset;
            var endUtc = endDateTimeLocal - MyanmarOffset;

            var request = new
            {
                ModuleId = _editModuleId,
                SessionDate = _editSessionDate,
                StartDatetime = startUtc,
                EndDatetime = endUtc,
                Status = _editStatus
            };

            var response = await Http.PutAsJsonAsync($"api/classsessions/{_editingSession.Id}", request);
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<ApiResult>();
                if (result != null && result.IsSuccess)
                {
                    _message = "Session updated successfully.";
                    _isError = false;
                    _showEditModal = false;
                    await LoadSessions();
                }
                else
                {
                    _message = result?.Message ?? "Failed to update session.";
                    _isError = true;
                }
            }
            else
            {
                _message = await response.GetFriendlyErrorMessageAsync("Error updating session");
                _isError = true;
            }
        }
        catch (Exception ex)
        {
            _message = ex.GetFriendlyErrorMessage("Error updating session");
            _isError = true;
        }
        finally
        {
            _isSaving = false;
        }
    }

    private async Task DeleteSession(long id)
    {
        _message = string.Empty;
        try
        {
            var response = await Http.DeleteAsync($"api/classsessions/{id}");
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<ApiResult>();
                if (result != null && result.IsSuccess)
                {
                    _message = "Session deleted successfully.";
                    _isError = false;
                    if (_sessions != null && _sessions.Count == 1 && _pageNumber > 1)
                    {
                        _pageNumber--;
                    }
                    await LoadSessions();
                }
                else
                {
                    _message = result?.Message ?? "Failed to delete session.";
                    _isError = true;
                }
            }
            else
            {
                _message = await response.GetFriendlyErrorMessageAsync("Error deleting session");
                _isError = true;
            }
        }
        catch (Exception ex)
        {
            _message = ex.GetFriendlyErrorMessage("Error deleting session");
            _isError = true;
        }
    }
