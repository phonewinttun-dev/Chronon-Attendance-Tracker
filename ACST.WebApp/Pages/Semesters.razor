@page "/semesters"
@using ACST.WebApp.Models
@inject HttpClient Http

<PageTitle>Semesters</PageTitle>

<div class="flex justify-between items-center mb-8">
    <h1 class="text-2xl font-bold tracking-tight text-foreground">Semesters</h1>
    <button class="bg-primary text-primary-foreground hover:bg-primary/90 px-4 py-2 rounded-md text-sm font-semibold transition-all" @onclick="ToggleCreateForm">
        @(_showCreateForm ? "Cancel" : "New Semester")
    </button>
</div>

@if (!string.IsNullOrEmpty(_message))
{
    <div class="border p-4 rounded-md mb-6 text-sm font-medium @(_isError ? "bg-destructive/10 border-destructive/30 text-destructive" : "bg-emerald-500/10 border-emerald-500/20 text-emerald-500")">
        @_message
    </div>
}

@if (_showCreateForm)
{
    <div class="bg-card border border-border p-6 rounded-lg shadow-sm mb-8">
        <h2 class="text-base font-bold mb-4 text-foreground tracking-tight">Create New Semester</h2>
        
        <div class="mb-4">
            <label class="block text-sm font-semibold text-muted-foreground mb-1">Name</label>
            <input type="text" class="w-full p-2.5 bg-background border border-border rounded-md text-foreground focus:outline-none focus:ring-1 focus:ring-ring" @bind="_newSemester.Name" placeholder="e.g. Fall 2026" />
        </div>
        
        <div class="grid grid-cols-2 gap-4 mb-6">
            <div>
                <label class="block text-sm font-semibold text-muted-foreground mb-1">Start Date</label>
                <DatePicker @bind-Value="_newSemester.StartDate" />
            </div>
            <div>
                <label class="block text-sm font-semibold text-muted-foreground mb-1">End Date</label>
                <DatePicker @bind-Value="_newSemester.EndDate" />
            </div>
        </div>

        <button class="bg-primary text-primary-foreground hover:bg-primary/90 px-4 py-2 rounded-md text-sm font-semibold transition-all disabled:opacity-50" @onclick="CreateSemester" disabled="@_isSubmitting">
            @(_isSubmitting ? "Creating..." : "Create Semester")
        </button>
    </div>
}

<div class="bg-card border border-border rounded-lg shadow-sm overflow-hidden">
    @if (_isLoading)
    {
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse text-xs animate-pulse">
                <thead>
                    <tr class="border-b border-border bg-muted/50">
                        <th class="px-6 py-3.5 font-semibold text-muted-foreground uppercase tracking-wider">Name</th>
                        <th class="px-6 py-3.5 font-semibold text-muted-foreground uppercase tracking-wider">Start Date</th>
                        <th class="px-6 py-3.5 font-semibold text-muted-foreground uppercase tracking-wider">End Date</th>
                        <th class="px-6 py-3.5 font-semibold text-muted-foreground uppercase tracking-wider">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-border">
                    @for (int i = 0; i < 4; i++)
                    {
                        <tr>
                            <td class="px-6 py-4">
                                <div class="h-3 bg-muted rounded w-28"></div>
                            </td>
                            <td class="px-6 py-4">
                                <div class="h-3 bg-muted rounded w-20"></div>
                            </td>
                            <td class="px-6 py-4">
                                <div class="h-3 bg-muted rounded w-20"></div>
                            </td>
                            <td class="px-6 py-4">
                                <div class="h-7 bg-muted rounded w-16"></div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else if (_semesters == null || !_semesters.Any())
    {
        <div class="p-6 text-muted-foreground text-sm">No semesters found. Create one to get started.</div>
    }
    else
    {
        <table class="w-full text-left border-collapse text-xs">
            <thead>
                <tr class="border-b border-border bg-muted/50">
                    <th class="px-6 py-3.5 font-semibold text-muted-foreground uppercase tracking-wider">Name</th>
                    <th class="px-6 py-3.5 font-semibold text-muted-foreground uppercase tracking-wider">Start Date</th>
                    <th class="px-6 py-3.5 font-semibold text-muted-foreground uppercase tracking-wider">End Date</th>
                    <th class="px-6 py-3.5 font-semibold text-muted-foreground uppercase tracking-wider">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-border">
                @foreach (var sem in _semesters)
                {
                    <tr class="hover:bg-accent/40 transition-colors">
                        <td class="px-6 py-3 text-foreground font-medium">@sem.Name</td>
                        <td class="px-6 py-3 font-mono text-muted-foreground">@sem.StartDate.ToString("dd-MM-yyyy")</td>
                        <td class="px-6 py-3 font-mono text-muted-foreground">@sem.EndDate.ToString("dd-MM-yyyy")</td>
                        <td class="px-6 py-3">
                            <button class="text-destructive hover:bg-destructive/10 border border-destructive/20 px-3 py-1 rounded transition-all text-xs font-semibold" @onclick="() => DeleteSemester(sem.Id)">Delete</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

@code {
    private List<SemesterDto>? _semesters;
    private bool _isLoading = true;
    private bool _showCreateForm = false;
    private bool _isSubmitting = false;
    private string _message = string.Empty;
    private bool _isError = false;

    private CreateSemesterRequest _newSemester = new()
    {
        StartDate = DateOnly.FromDateTime(DateTime.Today),
        EndDate = DateOnly.FromDateTime(DateTime.Today.AddMonths(4))
    };

    protected override async Task OnInitializedAsync()
    {
        await LoadSemesters();
    }

    private void ToggleCreateForm()
    {
        _showCreateForm = !_showCreateForm;
        _message = string.Empty;
    }

    private async Task LoadSemesters()
    {
        _isLoading = true;
        try
        {
            var result = await Http.GetFromJsonAsync<ApiResult<List<SemesterDto>>>("api/semesters");
            if (result != null && result.IsSuccess)
            {
                _semesters = result.Data;
            }
        }
        catch (Exception ex)
        {
            _message = "Error loading semesters: " + ex.Message;
            _isError = true;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task CreateSemester()
    {
        _isSubmitting = true;
        _message = string.Empty;

        try
        {
            var response = await Http.PostAsJsonAsync("api/semesters", _newSemester);
            var result = await response.Content.ReadFromJsonAsync<ApiResult<SemesterDto>>();

            if (result != null && result.IsSuccess)
            {
                _message = "Semester created successfully.";
                _isError = false;
                _showCreateForm = false;
                _newSemester = new CreateSemesterRequest
                {
                    StartDate = DateOnly.FromDateTime(DateTime.Today),
                    EndDate = DateOnly.FromDateTime(DateTime.Today.AddMonths(4))
                };
                await LoadSemesters();
            }
            else
            {
                _message = result?.Message ?? "Unknown error creating semester.";
                _isError = true;
            }
        }
        catch (Exception ex)
        {
            _message = "Error: " + ex.Message;
            _isError = true;
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    private async Task DeleteSemester(long id)
    {
        try
        {
            var response = await Http.DeleteAsync($"api/semesters/{id}");
            if (response.IsSuccessStatusCode)
            {
                await LoadSemesters();
            }
        }
        catch
        {
            // Handle error
        }
    }
}
