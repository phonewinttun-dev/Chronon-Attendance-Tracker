@page "/semesters"
@using ACST.WebApp.Models
@inject HttpClient Http

<PageTitle>Semesters</PageTitle>

<div class="flex justify-between items-center mb-8">
    <h1 class="text-3xl font-bold">Semesters</h1>
    <button class="bg-primary hover:bg-primary-fixed-dim text-on-primary font-medium px-4 py-2 rounded-md transition-colors" @onclick="ToggleCreateForm">
        @(_showCreateForm ? "Cancel" : "New Semester")
    </button>
</div>

@if (!string.IsNullOrEmpty(_message))
{
    <div class="bg-surface-container border @(_isError ? "border-error text-error" : "border-primary text-primary") p-4 rounded-md mb-6">
        @_message
    </div>
}

@if (_showCreateForm)
{
    <div class="bg-surface-container border border-outline-variant p-6 rounded-md shadow-md mb-8">
        <h2 class="text-xl font-bold mb-4 text-on-surface">Create New Semester</h2>
        
        <div class="mb-4">
            <label class="block text-on-surface-variant mb-2">Name</label>
            <input type="text" class="w-full p-3 bg-surface border border-outline-variant rounded-md text-on-surface focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary" @bind="_newSemester.Name" placeholder="e.g. Fall 2026" />
        </div>
        
        <div class="grid grid-cols-2 gap-4 mb-6">
            <div>
                <label class="block text-on-surface-variant mb-2">Start Date</label>
                <DatePicker @bind-Value="_newSemester.StartDate" />
            </div>
            <div>
                <label class="block text-on-surface-variant mb-2">End Date</label>
                <DatePicker @bind-Value="_newSemester.EndDate" />
            </div>
        </div>

        <button class="bg-primary hover:bg-primary-fixed-dim text-on-primary font-medium px-6 py-3 rounded-md transition-colors disabled:opacity-50" @onclick="CreateSemester" disabled="@_isSubmitting">
            @(_isSubmitting ? "Creating..." : "Create Semester")
        </button>
    </div>
}

<div class="bg-surface-container border border-outline-variant rounded-md shadow-md overflow-hidden">
    @if (_isLoading)
    {
        <div class="p-6 text-on-surface-variant">Loading semesters...</div>
    }
    else if (_semesters == null || !_semesters.Any())
    {
        <div class="p-6 text-on-surface-variant">No semesters found. Create one to get started.</div>
    }
    else
    {
        <table class="w-full text-left border-collapse">
            <thead>
                <tr class="border-b border-outline-variant bg-surface-variant">
                    <th class="px-6 py-4 text-xs font-semibold text-on-surface-variant uppercase tracking-wider">Name</th>
                    <th class="px-6 py-4 text-xs font-semibold text-on-surface-variant uppercase tracking-wider">Start Date</th>
                    <th class="px-6 py-4 text-xs font-semibold text-on-surface-variant uppercase tracking-wider">End Date</th>
                    <th class="px-6 py-4 text-xs font-semibold text-on-surface-variant uppercase tracking-wider">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-outline-variant">
                @foreach (var sem in _semesters)
                {
                    <tr class="hover:bg-surface-variant/50 transition-colors">
                        <td class="px-6 py-4">@sem.Name</td>
                        <td class="px-6 py-4 font-mono text-sm">@sem.StartDate.ToString("dd-MM-yyyy")</td>
                        <td class="px-6 py-4 font-mono text-sm">@sem.EndDate.ToString("dd-MM-yyyy")</td>
                        <td class="px-6 py-4">
                            <button class="text-error border border-error px-3 py-1 rounded hover:bg-error hover:text-on-error transition-colors text-sm" @onclick="() => DeleteSemester(sem.Id)">Delete</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

@code {
    private List<SemesterDto>? _semesters;
    private bool _isLoading = true;
    private bool _showCreateForm = false;
    private bool _isSubmitting = false;
    private string _message = string.Empty;
    private bool _isError = false;

    private CreateSemesterRequest _newSemester = new()
    {
        StartDate = DateOnly.FromDateTime(DateTime.Today),
        EndDate = DateOnly.FromDateTime(DateTime.Today.AddMonths(4))
    };

    protected override async Task OnInitializedAsync()
    {
        await LoadSemesters();
    }

    private void ToggleCreateForm()
    {
        _showCreateForm = !_showCreateForm;
        _message = string.Empty;
    }

    private async Task LoadSemesters()
    {
        _isLoading = true;
        try
        {
            var result = await Http.GetFromJsonAsync<ApiResult<List<SemesterDto>>>("api/semesters");
            if (result != null && result.IsSuccess)
            {
                _semesters = result.Data;
            }
        }
        catch (Exception ex)
        {
            _message = "Error loading semesters: " + ex.Message;
            _isError = true;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task CreateSemester()
    {
        _isSubmitting = true;
        _message = string.Empty;

        try
        {
            var response = await Http.PostAsJsonAsync("api/semesters", _newSemester);
            var result = await response.Content.ReadFromJsonAsync<ApiResult<SemesterDto>>();

            if (result != null && result.IsSuccess)
            {
                _message = "Semester created successfully.";
                _isError = false;
                _showCreateForm = false;
                _newSemester = new CreateSemesterRequest
                {
                    StartDate = DateOnly.FromDateTime(DateTime.Today),
                    EndDate = DateOnly.FromDateTime(DateTime.Today.AddMonths(4))
                };
                await LoadSemesters();
            }
            else
            {
                _message = result?.Message ?? "Unknown error creating semester.";
                _isError = true;
            }
        }
        catch (Exception ex)
        {
            _message = "Error: " + ex.Message;
            _isError = true;
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    private async Task DeleteSemester(long id)
    {
        try
        {
            var response = await Http.DeleteAsync($"api/semesters/{id}");
            if (response.IsSuccessStatusCode)
            {
                await LoadSemesters();
            }
        }
        catch
        {
            // Handle error
        }
    }
}
