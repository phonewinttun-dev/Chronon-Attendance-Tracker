@page "/register"
@using ACST.WebApp.Models
@inject HttpClient Http
@inject NavigationManager Navigation

<PageTitle>Register Account (US-18) - Chronon Tracker</PageTitle>

<div class="min-h-[85vh] flex items-center justify-center py-12 px-4 sm:px-6 lg:px-8">
    <div class="max-w-lg w-full space-y-8 bg-card border border-border/80 rounded-2xl p-8 shadow-2xl animate-in zoom-in-95 duration-200">
        
        <!-- Header -->
        <div class="text-center space-y-2">
            <div class="inline-flex items-center justify-center w-12 h-12 rounded-xl bg-primary/10 text-primary mb-2 border border-primary/20">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-6 h-6"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><line x1="19" y1="8" x2="19" y2="14"/><line x1="22" y1="11" x2="16" y2="11"/></svg>
            </div>
            <h2 class="text-2xl font-bold tracking-tight text-foreground font-sans">Create Your Account</h2>
            <p class="text-xs text-muted-foreground">Register your new account to access the attendance tracking hub (US-18)</p>
        </div>

        <!-- Alert Message -->
        @if (!string.IsNullOrEmpty(_message))
        {
            <div class="p-3.5 rounded-lg border text-xs font-medium flex items-center justify-between gap-2.5 @(_isError ? "bg-destructive/10 border-destructive/30 text-destructive" : "bg-primary/10 border-primary/30 text-primary")">
                <div class="flex items-center gap-2.5">
                    @if (_isError)
                    {
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-4 h-4 shrink-0"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                    }
                    else
                    {
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-4 h-4 shrink-0"><path d="M20 6 9 17l-5-5"/></svg>
                    }
                    <span>@_message</span>
                </div>
            </div>
        }

        <!-- Form -->
        <EditForm Model="@_registerModel" OnValidSubmit="HandleRegister" class="mt-6 space-y-4">
            <DataAnnotationsValidator />

            <!-- Full Name -->
            <div>
                <label class="block text-xs font-semibold text-foreground mb-1.5">Full Name <span class="text-destructive">*</span></label>
                <div class="relative">
                    <input type="text" 
                           class="w-full pl-10 pr-4 py-2.5 bg-background border border-border rounded-lg text-foreground focus:outline-none focus:ring-2 focus:ring-primary/30 text-xs transition-all placeholder:text-muted-foreground" 
                           placeholder="John Doe" 
                           @bind="_registerModel.FullName" 
                           required />
                    <div class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none text-muted-foreground">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-4 h-4"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                    </div>
                </div>
            </div>

            <!-- Email Address -->
            <div>
                <label class="block text-xs font-semibold text-foreground mb-1.5">Email Address <span class="text-destructive">*</span></label>
                <div class="relative">
                    <input type="email" 
                           class="w-full pl-10 pr-4 py-2.5 bg-background border border-border rounded-lg text-foreground focus:outline-none focus:ring-2 focus:ring-primary/30 text-xs transition-all placeholder:text-muted-foreground" 
                           placeholder="you@example.com" 
                           @bind="_registerModel.Email" 
                           required />
                    <div class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none text-muted-foreground">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-4 h-4"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
                    </div>
                </div>
            </div>

            <!-- Mobile Number -->
            <div>
                <label class="block text-xs font-semibold text-foreground mb-1.5">Mobile Number (Optional)</label>
                <div class="relative">
                    <input type="tel" 
                           class="w-full pl-10 pr-4 py-2.5 bg-background border border-border rounded-lg text-foreground focus:outline-none focus:ring-2 focus:ring-primary/30 text-xs transition-all placeholder:text-muted-foreground" 
                           placeholder="+95 9 1234 5678" 
                           @bind="_registerModel.MobileNum" />
                    <div class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none text-muted-foreground">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-4 h-4"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                    </div>
                </div>
            </div>

            <!-- Role Selection -->
            <div>
                <label class="block text-xs font-semibold text-foreground mb-1.5">Role Assignment <span class="text-destructive">*</span></label>
                <div class="relative">
                    <select class="w-full pl-10 pr-8 py-2.5 bg-background border border-border rounded-lg text-foreground focus:outline-none focus:ring-2 focus:ring-primary/30 text-xs transition-all appearance-none cursor-pointer"
                            @bind="_registerModel.RoleId" 
                            required>
                        <option value="0">-- Select Role --</option>
                        @if (_roles != null)
                        {
                            @foreach (var role in _roles)
                            {
                                <option value="@role.RoleId">@role.RoleName</option>
                            }
                        }
                    </select>
                    <div class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none text-muted-foreground">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-4 h-4"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                    </div>
                    <div class="absolute inset-y-0 right-0 pr-3 flex items-center pointer-events-none text-muted-foreground">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-4 h-4"><path d="m6 9 6 6 6-6"/></svg>
                    </div>
                </div>
            </div>

            <!-- Password -->
            <div>
                <label class="block text-xs font-semibold text-foreground mb-1.5">Password <span class="text-destructive">*</span></label>
                <div class="relative">
                    <input type="password" 
                           class="w-full pl-10 pr-4 py-2.5 bg-background border border-border rounded-lg text-foreground focus:outline-none focus:ring-2 focus:ring-primary/30 text-xs transition-all placeholder:text-muted-foreground" 
                           placeholder="Minimum 6 characters" 
                           @bind="_registerModel.Password" 
                           required />
                    <div class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none text-muted-foreground">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-4 h-4"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                    </div>
                </div>
            </div>

            <button type="submit" 
                    disabled="@_isSubmitting" 
                    class="w-full bg-primary text-primary-foreground hover:bg-primary/90 py-2.5 rounded-lg text-xs font-bold transition-all shadow-md disabled:opacity-50 flex items-center justify-center gap-2 mt-6">
                @if (_isSubmitting)
                {
                    <svg class="animate-spin h-4 w-4 text-primary-foreground" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
                    <span>Registering Account...</span>
                }
                else
                {
                    <span>Register Account</span>
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-4 h-4"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                }
            </button>
        </EditForm>

        <!-- Footer Link -->
        <div class="text-center border-t border-border/60 pt-4">
            <p class="text-xs text-muted-foreground">
                Already registered? 
                <a href="login" class="font-semibold text-primary hover:underline">Sign in here</a>
            </p>
        </div>
    </div>
</div>

@code {
    private RegisterRequestDto _registerModel = new();
    private List<RoleDto>? _roles;
    private bool _isSubmitting = false;
    private string? _message;
    private bool _isError = false;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var res = await Http.GetFromJsonAsync<ApiResult<List<RoleDto>>>("api/RolePermission/roles");
            if (res?.IsSuccess == true && res.Data != null)
            {
                _roles = res.Data;
                if (_roles.Any())
                {
                    _registerModel.RoleId = _roles.First().RoleId;
                }
            }
        }
        catch { }
    }

    private async Task HandleRegister()
    {
        if (_registerModel.RoleId == 0)
        {
            _message = "Please select a valid role.";
            _isError = true;
            return;
        }

        _isSubmitting = true;
        _message = null;

        try
        {
            var response = await Http.PostAsJsonAsync("api/Auth/register", _registerModel);
            var result = await response.Content.ReadFromJsonAsync<ApiResult<UserAccountDto>>();

            if (response.IsSuccessStatusCode && result?.IsSuccess == true)
            {
                _message = "Account registered successfully! Redirecting to login...";
                _isError = false;
                
                await Task.Delay(1200);
                Navigation.NavigateTo("login");
            }
            else
            {
                _message = result?.Message ?? "Registration failed. Please check details.";
                _isError = true;
            }
        }
        catch (Exception ex)
        {
            _message = $"Error: {ex.Message}";
            _isError = true;
        }
        finally
        {
            _isSubmitting = false;
        }
    }
}
