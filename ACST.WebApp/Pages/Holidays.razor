@page "/holidays"
@using ACST.WebApp.Models
@inject HttpClient Http

<PageTitle>Holidays</PageTitle>

<div class="mb-8 flex flex-col md:flex-row md:items-center justify-between gap-4">
    <div>
        <h1 class="text-2xl font-bold tracking-tight text-foreground">Holidays</h1>
        <p class="text-muted-foreground text-sm mt-1">Manage public holidays which are excluded from attendance tracking.</p>
    </div>
    <button class="bg-primary text-primary-foreground hover:bg-primary/90 font-medium px-4 py-2 rounded-md text-sm transition-colors disabled:opacity-50" @onclick="SeedHolidays" disabled="@_isSeeding">
        @(_isSeeding ? "Seeding..." : "Seed from JSON")
    </button>
</div>

@if (!string.IsNullOrEmpty(_message))
{
    <div class="border p-4 rounded-lg mb-6 text-sm font-semibold flex items-center justify-between gap-3 transition-all @(_isError ? "bg-destructive/10 border-destructive/30 text-destructive" : "bg-emerald-500/10 border-emerald-500/20 text-emerald-500")">
        <div class="flex items-center gap-2.5">
            @if (_isError)
            {
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 shrink-0"><circle cx="12" cy="12" r="10"/><line x1="12" x2="12" y1="8" y2="12"/><line x1="12" x2="12.01" y1="16" y2="16"/></svg>
            }
            else
            {
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 shrink-0"><path d="M20 6 9 17l-5-5"/></svg>
            }
            <span>@_message</span>
        </div>
        <button class="hover:opacity-80 focus:outline-none text-base font-bold px-1.5 py-0.5 rounded hover:bg-foreground/5 transition-all" @onclick="() => _message = string.Empty" title="Dismiss">×</button>
    </div>
}

<div class="bg-card border border-border rounded-lg shadow-sm overflow-hidden">
    @if (_isLoading)
    {
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse text-xs animate-pulse">
                <thead>
                    <tr class="border-b border-border bg-muted/50">
                        <th class="px-6 py-3.5 font-semibold text-muted-foreground uppercase tracking-wider">Name</th>
                        <th class="px-6 py-3.5 font-semibold text-muted-foreground uppercase tracking-wider">Date</th>
                        <th class="px-6 py-3.5 font-semibold text-muted-foreground uppercase tracking-wider w-28">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-border">
                    @for (int i = 0; i < 5; i++)
                    {
                        <tr>
                            <td class="px-6 py-4">
                                <div class="h-3 bg-muted rounded w-36"></div>
                            </td>
                            <td class="px-6 py-4">
                                <div class="h-3 bg-muted rounded w-20"></div>
                            </td>
                            <td class="px-6 py-4">
                                <div class="h-7 bg-muted rounded w-20"></div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else if (_holidays == null || !_holidays.Any())
    {
        <div class="p-6 text-muted-foreground text-sm">No holidays found.</div>
    }
    else
    {
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse text-sm">
                <thead>
                    <tr class="border-b border-border bg-muted/40">
                        <th class="px-6 py-3 font-semibold text-muted-foreground">Name</th>
                        <th class="px-6 py-3 font-semibold text-muted-foreground">Date</th>
                        <th class="px-6 py-3 font-semibold text-muted-foreground w-28">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-border">
                    @foreach (var holiday in _holidays)
                    {
                        <tr class="hover:bg-muted/40 transition-colors">
                            <td class="px-6 py-3 text-foreground font-medium">@holiday.Name</td>
                            <td class="px-6 py-3 font-mono text-muted-foreground">@holiday.HolidayDate.ToString("dd-MM-yyyy")</td>
                            <td class="px-6 py-3">
                                <button class="text-destructive border border-destructive/30 hover:bg-destructive hover:text-destructive-foreground px-3 py-1 rounded transition-colors text-xs font-semibold w-20" @onclick="() => DeleteHoliday(holiday.Id)">Delete</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div class="border-t border-border bg-card">
            <PaginationControl PageNumber="@_pageNumber" TotalPages="@_totalPages" PageChanged="OnPageChanged" />
        </div>
    }
</div>

@code {
    private List<HolidayDto>? _holidays;
    private bool _isLoading = true;
    private bool _isSeeding = false;
    private string _message = string.Empty;
    private bool _isError = false;

    private int _pageNumber = 1;
    private int _pageSize = 10;
    private int _totalPages = 1;
    private int _totalCount = 0;
    private bool _hasPrevious = false;
    private bool _hasNext = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadHolidays();
    }

    private async Task OnPageChanged(int newPage)
    {
        _pageNumber = newPage;
        await LoadHolidays();
    }

    private async Task LoadHolidays()
    {
        _isLoading = true;
        try
        {
            var result = await Http.GetFromJsonAsync<PagedResult<HolidayDto>>($"api/holidays?pageNumber={_pageNumber}&pageSize={_pageSize}");
            if (result != null && result.IsSuccess)
            {
                _holidays = result.Data;
                _pageNumber = result.Pagination.PageNumber;
                _pageSize = result.Pagination.PageSize;
                _totalPages = result.Pagination.TotalPages;
                _totalCount = result.Pagination.TotalCount;
                _hasPrevious = result.Pagination.HasPreviousPage;
                _hasNext = result.Pagination.HasNextPage;
            }
        }
        catch (Exception ex)
        {
            _message = ex.GetFriendlyErrorMessage("Error loading holidays");
            _isError = true;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task SeedHolidays()
    {
        _isSeeding = true;
        _message = string.Empty;

        try
        {
            var response = await Http.PostAsync("api/holidays/seed", null);
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<ApiResult>();
                if (result != null && result.IsSuccess)
                {
                    _message = result.Message;
                    _isError = false;
                    _pageNumber = 1;
                    await LoadHolidays();
                }
                else
                {
                    _message = result?.Message ?? "Unknown error seeding holidays.";
                    _isError = true;
                }
            }
            else
            {
                _message = await response.GetFriendlyErrorMessageAsync("Error seeding holidays");
                _isError = true;
            }
        }
        catch (Exception ex)
        {
            _message = ex.GetFriendlyErrorMessage("Error seeding holidays");
            _isError = true;
        }
        finally
        {
            _isSeeding = false;
        }
    }

    private async Task DeleteHoliday(long id)
    {
        _message = string.Empty;
        try
        {
            var response = await Http.DeleteAsync($"api/holidays/{id}");
            if (response.IsSuccessStatusCode)
            {
                _message = "Holiday deleted successfully.";
                _isError = false;
                if (_holidays != null && _holidays.Count == 1 && _pageNumber > 1)
                {
                    _pageNumber--;
                }
                await LoadHolidays();
            }
            else
            {
                _message = await response.GetFriendlyErrorMessageAsync("Error deleting holiday");
                _isError = true;
            }
        }
        catch (Exception ex)
        {
            _message = ex.GetFriendlyErrorMessage("Error deleting holiday");
            _isError = true;
        }
    }
}
