@page "/"
@using ACST.WebApp.Models
@inject HttpClient Http
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>Dashboard</PageTitle>

@if (_isLoadingSemesters)
{
    <div class="mb-8 flex flex-col md:flex-row md:items-center justify-between gap-4 animate-pulse">
        <div>
            <div class="flex items-center gap-3">
                <h1 class="text-2xl font-bold tracking-tight text-foreground">Dashboard</h1>
                <div class="h-5 bg-muted rounded-full w-28"></div>
            </div>
            <div class="h-4 bg-muted rounded w-64 mt-2"></div>
        </div>
        <div class="flex items-center gap-3">
            <div class="h-4 bg-muted rounded w-16"></div>
            <div class="h-9 bg-muted rounded w-[220px]"></div>
        </div>
    </div>
    @RenderDashboardSkeletons
}
else if (_isError)
{
    <div class="mb-8 flex flex-col md:flex-row md:items-center justify-between gap-4">
        <div>
            <div class="flex items-center gap-3">
                <h1 class="text-2xl font-bold tracking-tight text-foreground">Dashboard</h1>
            </div>
        </div>
    </div>
    @RenderDashboardSkeletons

    <div class="fixed inset-0 bg-background/30 backdrop-blur-md flex items-center justify-center z-50">
        <div class="bg-card border border-border rounded-xl p-8 max-w-sm w-full shadow-2xl text-center animate-in zoom-in duration-200">
            <div class="mx-auto flex items-center justify-center h-12 w-12 rounded-full bg-destructive/10 text-destructive mb-4">
                <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                </svg>
            </div>
            <h3 class="text-lg font-bold text-foreground mb-2">Unexpected Error Occurred</h3>
            <p class="text-xs text-muted-foreground mb-6 leading-relaxed">Failed to connect to the server or load required data. Please check your connection and try again.</p>
            <button class="w-full py-2 bg-error text-error-foreground hover:bg-error/90 rounded-md text-xs font-semibold transition-all shadow-md focus:outline-none"
                    @onclick="LoadInitialData">
                Refresh
            </button>
        </div>
    </div>
}
else if (_semesters == null || !_semesters.Any())
{
    <div class="flex justify-between items-center mb-8">
        <h1 class="text-2xl font-bold tracking-tight text-foreground">Dashboard</h1>
    </div>
    <div class="bg-surface-container border border-border/40 p-8 rounded-xl text-center max-w-md mx-auto my-12 bg-card">
        <div class="mx-auto flex items-center justify-center h-12 w-12 rounded-full bg-primary/10 text-primary mb-4">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
            </svg>
        </div>
        <h3 class="font-bold text-lg mb-2 text-foreground">No Semesters Found</h3>
        <p class="text-muted-foreground text-sm mb-6">Please create a semester first to view dashboard analytics.</p>
        <button class="bg-primary text-primary-foreground hover:bg-primary/90 px-5 py-2.5 rounded-lg text-sm font-semibold transition-all shadow-md focus:outline-none"
                @onclick='() => Navigation.NavigateTo("/semesters")'>
            Create A Semester
        </button>
    </div>
}
else
{
    <div class="mb-8 flex flex-col md:flex-row md:items-center justify-between gap-4">
        <div>
            <div class="flex items-center gap-3">
                <h1 class="text-2xl font-bold tracking-tight text-foreground">Dashboard</h1>
                @if (_selectedSemesterId == _currentSemesterId)
                {
                    <span class="bg-emerald-500/10 text-emerald-500 border border-emerald-500/20 px-2.5 py-0.5 rounded-full text-xs font-medium">Current Semester</span>
                }
                else
                {
                    <span class="bg-muted text-muted-foreground border border-border px-2.5 py-0.5 rounded-full text-xs font-medium">Previous Semester</span>
                }
            </div>
            @if (_summary != null)
            {
                <p class="text-muted-foreground text-sm mt-1">
                    Academic Period: <span class="font-mono text-foreground">@_summary.StartDate.ToString("dd-MM-yyyy")</span> to <span class="font-mono text-foreground">@_summary.EndDate.ToString("dd-MM-yyyy")</span>
                </p>
            }
        </div>
        <div class="flex items-center gap-3">
            <label class="text-muted-foreground font-semibold text-sm whitespace-nowrap">Semester:</label>
            <select class="p-2 bg-card border border-border rounded-md text-foreground font-sans text-sm focus:outline-none focus:ring-1 focus:ring-ring min-w-[220px]"
                    value="@_selectedSemesterId" @onchange="OnSemesterChanged">
                @foreach (var sem in _semesters)
                {
                    <option value="@sem.Id">@sem.Name</option>
                }
            </select>
        </div>
    </div>

    @if (_isLoadingSummary)
    {
        @RenderDashboardSkeletons
    }
    else if (_summary == null)
    {
        <div class="bg-card border border-destructive/50 p-6 rounded-lg text-destructive text-sm font-semibold">
            Failed to load dashboard data for the selected semester.
        </div>
    }
    else
    {
        <!-- Metrics Cards -->
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
            <div class="bg-card border border-border p-6 rounded-lg shadow-sm">
                <h3 class="text-muted-foreground text-sm font-medium tracking-tight mb-1">Today's Classes</h3>
                <div class="text-3xl font-bold text-foreground font-mono">
                    @_summary.TodaySessionsCount
                </div>
            </div>

            <div class="bg-card border border-border p-6 rounded-lg shadow-sm hover:border-primary/50 transition-all cursor-pointer" @onclick='() => Navigation.NavigateTo("/calendar")'>
                <h3 class="text-muted-foreground text-sm font-medium tracking-tight mb-1">Upcoming Classes (7 days)</h3>
                <div class="text-3xl font-bold text-foreground font-mono">
                    @_summary.UpcomingSessionsCount
                </div>
            </div>

            <div class="bg-card border border-border p-6 rounded-lg shadow-sm relative overflow-hidden hover:border-primary/50 transition-all cursor-pointer" @onclick="() => SetActiveTab(Tab.Module)">
                <h3 class="text-muted-foreground text-sm font-medium tracking-tight mb-1">Semester Attendance</h3>
                <div class="text-3xl font-bold font-mono @GetHealthColorClass(_summary.SemesterHealthRate)">
                    @_summary.SemesterHealthRate%
                </div>
            </div>

            <div class="bg-card border border-border p-6 rounded-lg shadow-sm relative overflow-hidden hover:border-primary/50 transition-all cursor-pointer" @onclick="() => SetActiveTab(Tab.Daily)">
                <h3 class="text-muted-foreground text-sm font-medium tracking-tight mb-1">Today's Attendance</h3>
                <div class="text-3xl font-bold font-mono @GetHealthColorClass(_summary.TodayAttendanceRate ?? 0)">
                    @(_summary.TodayAttendanceRate ?? 0)%
                </div>
            </div>
        </div>

        @if (_summary.Warnings.Any())
        {
            <div class="bg-card border border-destructive/40 p-5 rounded-lg shadow-sm mb-8">
                <h3 class="text-destructive font-semibold text-sm mb-2 flex items-center gap-2">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 text-destructive shrink-0 lucide lucide-triangle-alert">
                        <path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/>
                        <line x1="12" y1="9" x2="12" y2="13"/>
                        <line x1="12" y1="17" x2="12.01" y2="17"/>
                    </svg>
                    Alerts
                </h3>
                <ul class="list-disc pl-5 text-muted-foreground text-xs space-y-0.5">
                    @foreach (var warning in _summary.Warnings)
                    {
                        <li class="mb-1">@warning</li>
                    }
                </ul>
            </div>
        }

        <!-- Reconciliation Grid & Details -->
        <div class="bg-card border border-border rounded-lg shadow-sm p-6 mb-8">
            <h2 class="text-base font-bold text-foreground mb-4 tracking-tight">Data Reconciliation</h2>
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
                <div>
                    <p class="text-muted-foreground text-sm leading-relaxed mb-4 font-sans">
                        Reconciliation provides a transparent breakdown of all academic session records for the semester. 
                        Public holidays and cancelled sessions are strictly excluded from the attendance statistics as per calculation guidelines.
                    </p>
                    <div class="bg-background border border-border rounded-md p-4 font-mono text-[11px] text-muted-foreground">
                        <div class="text-foreground font-semibold mb-1.5">// Attendance Rate Formula</div>
                        <div>Rate = Present / Valid Sessions * 100</div>
                        <div>Valid = Total - (Cancelled + Holiday)</div>
                        <div class="mt-3 text-foreground font-semibold">// Active Calculation</div>
                        <div>Rate = @_summary.PresentSessions / @_summary.ValidSessions * 100 = <span class="text-foreground font-bold">@_summary.CalculatedRate%</span></div>
                    </div>
                </div>
                
                <div class="border border-border rounded-md overflow-hidden bg-background/30">
                    <table class="w-full text-left text-sm font-sans">
                        <tbody class="divide-y divide-border">
                            <tr class="hover:bg-accent/40 transition-colors cursor-pointer" @onclick='() => Navigation.NavigateTo($"/sessions?semesterId={_selectedSemesterId}")'>
                                <td class="px-4 py-2.5 font-medium text-muted-foreground">Total Generated Sessions</td>
                                <td class="px-4 py-2.5 font-mono text-right text-foreground font-semibold">@_summary.TotalSessions</td>
                            </tr>
                            <tr class="hover:bg-accent/40 transition-colors text-emerald-500 font-medium cursor-pointer" @onclick='() => NavigateToStatus("Present")'>
                                <td class="px-4 py-2.5">Present Sessions (+)</td>
                                <td class="px-4 py-2.5 font-mono text-right font-bold">@_summary.PresentSessions</td>
                            </tr>
                            <tr class="hover:bg-accent/40 transition-colors text-destructive cursor-pointer" @onclick='() => NavigateToStatus("Absent")'>
                                <td class="px-4 py-2.5 font-medium">Absent Sessions (+)</td>
                                <td class="px-4 py-2.5 font-mono text-right">@_summary.AbsentSessions</td>
                            </tr>
                            <tr class="hover:bg-accent/40 transition-colors text-amber-500 cursor-pointer" @onclick='() => NavigateToStatus("Late")'>
                                <td class="px-4 py-2.5 font-medium">Late Sessions (+)</td>
                                <td class="px-4 py-2.5 font-mono text-right">@_summary.LateSessions</td>
                            </tr>
                            <tr class="hover:bg-accent/40 transition-colors text-muted-foreground cursor-pointer" @onclick='() => NavigateToStatus("Cancelled")'>
                                <td class="px-4 py-2.5 font-medium">Cancelled Sessions (Excluded, -)</td>
                                <td class="px-4 py-2.5 font-mono text-right">@_summary.CancelledSessions</td>
                            </tr>
                            <tr class="hover:bg-accent/40 transition-colors text-muted-foreground cursor-pointer" @onclick='() => NavigateToStatus("Holiday")'>
                                <td class="px-4 py-2.5 font-medium">Holiday Sessions (Excluded, -)</td>
                                <td class="px-4 py-2.5 font-mono text-right">@_summary.HolidaySessions</td>
                            </tr>
                            <tr class="bg-accent/30 hover:bg-accent/50 transition-colors font-bold text-foreground cursor-pointer" @onclick='() => Navigation.NavigateTo($"/sessions?semesterId={_selectedSemesterId}")'>
                                <td class="px-4 py-2.5">Total Valid Sessions (Denominator)</td>
                                <td class="px-4 py-2.5 font-mono text-right">@_summary.ValidSessions</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Daily, Weekly, Monthly Tabs -->
        <div id="attendance-breakdown" class="bg-card border border-border rounded-lg shadow-sm overflow-hidden mb-8">
            <div class="border-b border-border bg-accent/20 flex flex-col md:flex-row md:items-center justify-between p-2 gap-3">
                <div class="flex flex-wrap gap-1">
                    <button class="px-3 py-1.5 text-xs font-semibold rounded-md transition-all @(_activeTab == Tab.Daily ? "bg-background text-foreground shadow-sm" : "text-muted-foreground hover:bg-accent/50 hover:text-foreground")"
                            @onclick="() => SetActiveTab(Tab.Daily)">
                        Daily Attendance
                    </button>
                    <button class="px-3 py-1.5 text-xs font-semibold rounded-md transition-all @(_activeTab == Tab.Weekly ? "bg-background text-foreground shadow-sm" : "text-muted-foreground hover:bg-accent/50 hover:text-foreground")"
                            @onclick="() => SetActiveTab(Tab.Weekly)">
                        Weekly Attendance
                    </button>
                    <button class="px-3 py-1.5 text-xs font-semibold rounded-md transition-all @(_activeTab == Tab.Monthly ? "bg-background text-foreground shadow-sm" : "text-muted-foreground hover:bg-accent/50 hover:text-foreground")"
                            @onclick="() => SetActiveTab(Tab.Monthly)">
                        Monthly Attendance
                    </button>
                    <button class="px-3 py-1.5 text-xs font-semibold rounded-md transition-all @(_activeTab == Tab.Module ? "bg-background text-foreground shadow-sm" : "text-muted-foreground hover:bg-accent/50 hover:text-foreground")"
                            @onclick="() => SetActiveTab(Tab.Module)">
                        Module Attendance
                    </button>
                </div>

                <div class="flex flex-wrap items-center gap-2.5 mr-1">
                    <!-- Semester dropdown in card header -->
                    <div class="flex items-center gap-1.5">
                        <span class="text-muted-foreground text-xs font-semibold whitespace-nowrap">Semester:</span>
                        <select class="p-1 bg-card border border-border rounded text-foreground font-sans text-xs focus:outline-none focus:ring-1 focus:ring-ring min-w-[140px]"
                                value="@_selectedSemesterId" @onchange="OnSemesterChanged">
                            @foreach (var sem in _semesters)
                            {
                                <option value="@sem.Id">@sem.Name</option>
                            }
                        </select>
                    </div>

                    <div class="flex items-center gap-1 bg-muted border border-border p-1 rounded-md">
                        <button class="p-1 rounded transition-all @(_breakdownViewMode == "table" ? "bg-card text-foreground shadow-sm" : "text-muted-foreground hover:text-foreground")" 
                                @onclick='() => _breakdownViewMode = "table"' 
                                title="Table View">
                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-list"><line x1="8" x2="21" y1="6" y2="6"/><line x1="8" x2="21" y1="12" y2="12"/><line x1="8" x2="21" y1="18" y2="18"/><line x1="3" x2="3.01" y1="6" y2="6"/><line x1="3" x2="3.01" y1="12" y2="12"/><line x1="3" x2="3.01" y1="18" y2="18"/></svg>
                        </button>
                        <button class="p-1 rounded transition-all @(_breakdownViewMode == "card" ? "bg-card text-foreground shadow-sm" : "text-muted-foreground hover:text-foreground")" 
                                @onclick='() => _breakdownViewMode = "card"' 
                                title="Card View">
                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-layout-grid"><rect width="7" height="7" x="3" y="3" rx="1"/><rect width="7" height="7" x="14" y="3" rx="1"/><rect width="7" height="7" x="14" y="14" rx="1"/><rect width="7" height="7" x="3" y="14" rx="1"/></svg>
                        </button>
                    </div>
                </div>
            </div>

            <div class="p-6">
                @if (_activeTab == Tab.Daily)
                {
                    @if (_isLoadingDailyWeekly)
                    {
                        <div class="flex justify-center items-center py-12">
                            <div class="animate-spin rounded-full h-8 w-8 border-b-2 border-primary"></div>
                        </div>
                    }
                    else
                    {
                        @if (_breakdownViewMode == "table")
                        {
                        <div class="overflow-x-auto">
                            <table class="w-full text-left border-collapse text-sm">
                                <thead>
                                    <tr class="border-b border-outline-variant text-on-surface-variant">
                                        <th class="px-4 pb-3.5 font-semibold text-xs text-muted-foreground uppercase tracking-wider">Day of Week</th>
                                        <th class="px-4 pb-3.5 font-semibold text-xs text-muted-foreground uppercase tracking-wider text-center">Total</th>
                                        <th class="px-4 pb-3.5 font-semibold text-xs text-muted-foreground uppercase tracking-wider text-center">Present</th>
                                        <th class="px-4 pb-3.5 font-semibold text-xs text-muted-foreground uppercase tracking-wider text-center">Absent</th>
                                        <th class="px-4 pb-3.5 font-semibold text-xs text-muted-foreground uppercase tracking-wider text-center">Cancelled</th>
                                        <th class="px-4 pb-3.5 font-semibold text-xs text-muted-foreground uppercase tracking-wider text-center">Holiday</th>
                                        <th class="px-4 pb-3.5 font-semibold text-xs text-muted-foreground uppercase tracking-wider text-right">Attendance Rate</th>
                                    </tr>
                                </thead>
                                <tbody class="divide-y divide-outline-variant/50 text-sm">
                                    @foreach (var day in _summary.DailyAttendance)
                                    {
                                        <tr class="hover:bg-surface-variant/20 transition-colors text-on-surface-variant cursor-pointer" @onclick="() => NavigateToDaily(day.DayOfWeek)">
                                            <td class="px-4 py-3.5 font-sans text-sm font-semibold text-foreground">@day.DayOfWeek</td>
                                            <td class="px-4 py-3.5 text-center font-mono text-sm text-foreground">@day.TotalSessions</td>
                                            <td class="px-4 py-3.5 text-center font-mono text-sm text-primary font-bold">@day.Present</td>
                                            <td class="px-4 py-3.5 text-center font-mono text-sm text-error font-semibold">@day.Absent</td>
                                            <td class="px-4 py-3.5 text-center font-mono text-sm text-muted-foreground">@day.Cancelled</td>
                                            <td class="px-4 py-3.5 text-center font-mono text-sm text-muted-foreground">@day.Holiday</td>
                                            <td class="px-4 py-3.5 text-right">
                                                <span class="px-2.5 py-1 rounded-full text-xs font-bold font-sans border @GetBadgeBorderAndBg(day.AttendanceRate)">
                                                    @day.AttendanceRate%
                                                </span>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
                            @foreach (var day in _summary.DailyAttendance)
                            {
                                <div class="bg-card border border-border rounded-lg p-5 flex flex-col justify-between hover:border-primary/30 transition-all shadow-sm cursor-pointer" @onclick="() => NavigateToDaily(day.DayOfWeek)">
                                    <div class="flex items-center justify-between mb-3">
                                        <h3 class="text-sm font-semibold text-foreground">@day.DayOfWeek</h3>
                                        <span class="px-2.5 py-0.5 rounded-full text-[11px] font-bold font-sans border @GetBadgeBorderAndBg(day.AttendanceRate)">
                                            @day.AttendanceRate%
                                        </span>
                                    </div>
                                    <div class="grid grid-cols-2 gap-y-1.5 gap-x-4 text-xs font-mono text-muted-foreground border-t border-border/30 pt-3">
                                        <div>Total: <span class="text-foreground font-semibold">@day.TotalSessions</span></div>
                                        <div>Present: <span class="text-primary font-bold">@day.Present</span></div>
                                        <div>Absent: <span class="text-error font-semibold">@day.Absent</span></div>
                                        <div>Cancelled: <span class="text-foreground font-semibold">@day.Cancelled</span></div>
                                        <div>Holiday: <span class="text-foreground font-semibold">@day.Holiday</span></div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    }
                }
                else if (_activeTab == Tab.Weekly)
                {
                    @if (_isLoadingDailyWeekly)
                    {
                        <div class="flex justify-center items-center py-12">
                            <div class="animate-spin rounded-full h-8 w-8 border-b-2 border-primary"></div>
                        </div>
                    }
                    else
                    {
                        @if (_breakdownViewMode == "table")
                        {
                            <div class="overflow-x-auto">
                                <table class="w-full text-left border-collapse text-sm">
                                    <thead>
                                        <tr class="border-b border-outline-variant text-on-surface-variant">
                                            <th class="px-4 pb-3.5 font-semibold text-xs text-muted-foreground uppercase tracking-wider">Week</th>
                                            <th class="px-4 pb-3.5 font-semibold text-xs text-muted-foreground uppercase tracking-wider">Date Range</th>
                                            <th class="px-4 pb-3.5 font-semibold text-xs text-muted-foreground uppercase tracking-wider text-center">Total</th>
                                            <th class="px-4 pb-3.5 font-semibold text-xs text-muted-foreground uppercase tracking-wider text-center">Present</th>
                                            <th class="px-4 pb-3.5 font-semibold text-xs text-muted-foreground uppercase tracking-wider text-center">Absent</th>
                                            <th class="px-4 pb-3.5 font-semibold text-xs text-muted-foreground uppercase tracking-wider text-center">Cancelled</th>
                                            <th class="px-4 pb-3.5 font-semibold text-xs text-muted-foreground uppercase tracking-wider text-center">Holiday</th>
                                            <th class="px-4 pb-3.5 font-semibold text-xs text-muted-foreground uppercase tracking-wider text-right">Attendance Rate</th>
                                        </tr>
                                    </thead>
                                    <tbody class="divide-y divide-outline-variant/50 text-sm">
                                        @foreach (var week in _summary.WeeklyAttendance.Skip((_weeklyPageNumber - 1) * _weeklyPageSize).Take(_weeklyPageSize))
                                        {
                                            <tr class="hover:bg-surface-variant/20 transition-colors text-on-surface-variant cursor-pointer" @onclick="() => NavigateToWeekly(week.WeekStartDate, week.WeekEndDate)">
                                                <td class="px-4 py-3.5 font-sans text-sm font-semibold text-foreground">Week @week.WeekNumber</td>
                                                <td class="px-4 py-3.5 font-sans text-sm text-muted-foreground">@week.WeekStartDate.ToString("dd-MM-yyyy") ~ @week.WeekEndDate.ToString("dd-MM-yyyy")</td>
                                                <td class="px-4 py-3.5 text-center font-mono text-sm text-foreground">@week.TotalSessions</td>
                                                <td class="px-4 py-3.5 text-center font-mono text-sm text-primary font-bold">@week.Present</td>
                                                <td class="px-4 py-3.5 text-center font-mono text-sm text-error font-semibold">@week.Absent</td>
                                                <td class="px-4 py-3.5 text-center font-mono text-sm text-muted-foreground">@week.Cancelled</td>
                                                <td class="px-4 py-3.5 text-center font-mono text-sm text-muted-foreground">@week.Holiday</td>
                                                <td class="px-4 py-3.5 text-right">
                                                    <span class="px-2.5 py-1 rounded-full text-xs font-bold font-sans border @GetBadgeBorderAndBg(week.AttendanceRate)">
                                                        @week.AttendanceRate%
                                                    </span>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                        else
                        {
                            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
                                @foreach (var week in _summary.WeeklyAttendance.Skip((_weeklyPageNumber - 1) * _weeklyPageSize).Take(_weeklyPageSize))
                                {
                                    <div class="bg-card border border-border rounded-lg p-5 flex flex-col justify-between hover:border-primary/30 transition-all shadow-sm cursor-pointer" @onclick="() => NavigateToWeekly(week.WeekStartDate, week.WeekEndDate)">
                                        <div class="flex items-start justify-between mb-3">
                                            <div>
                                                <h3 class="text-sm font-semibold text-foreground">Week @week.WeekNumber</h3>
                                                <p class="text-[10px] text-muted-foreground font-mono mt-0.5">@week.WeekStartDate.ToString("dd-MM-yyyy") ~ @week.WeekEndDate.ToString("dd-MM-yyyy")</p>
                                            </div>
                                            <span class="px-2.5 py-0.5 rounded-full text-[11px] font-bold font-sans border @GetBadgeBorderAndBg(week.AttendanceRate)">
                                                @week.AttendanceRate%
                                            </span>
                                        </div>
                                        <div class="grid grid-cols-2 gap-y-1.5 gap-x-4 text-xs font-mono text-muted-foreground border-t border-border/30 pt-3">
                                            <div>Total: <span class="text-foreground font-semibold">@week.TotalSessions</span></div>
                                            <div>Present: <span class="text-primary font-bold">@week.Present</span></div>
                                            <div>Absent: <span class="text-error font-semibold">@week.Absent</span></div>
                                            <div>Cancelled: <span class="text-foreground font-semibold">@week.Cancelled</span></div>
                                            <div>Holiday: <span class="text-foreground font-semibold">@week.Holiday</span></div>
                                        </div>
                                    </div>
                                }
                            </div>
                        }

                        @if (GetWeeklyTotalPages() > 1)
                        {
                            <div class="border-t border-border mt-6">
                                <PaginationControl PageNumber="@_weeklyPageNumber" TotalPages="@GetWeeklyTotalPages()" PageChanged="OnWeeklyPageChanged" />
                            </div>
                        }
                    }
                }
                else if (_activeTab == Tab.Monthly)
                {
                    @if (_isLoadingDailyWeekly)
                    {
                        <div class="flex justify-center items-center py-12">
                            <div class="animate-spin rounded-full h-8 w-8 border-b-2 border-primary"></div>
                        </div>
                    }
                    else
                    {
                        @if (_breakdownViewMode == "table")
                        {
                            <div class="overflow-x-auto">
                                <table class="w-full text-left border-collapse text-sm">
                                    <thead>
                                        <tr class="border-b border-outline-variant text-on-surface-variant">
                                            <th class="px-4 pb-3.5 font-semibold text-xs text-muted-foreground uppercase tracking-wider">Month</th>
                                            <th class="px-4 pb-3.5 font-semibold text-xs text-muted-foreground uppercase tracking-wider text-center">Total</th>
                                            <th class="px-4 pb-3.5 font-semibold text-xs text-muted-foreground uppercase tracking-wider text-center">Present</th>
                                            <th class="px-4 pb-3.5 font-semibold text-xs text-muted-foreground uppercase tracking-wider text-center">Absent</th>
                                            <th class="px-4 pb-3.5 font-semibold text-xs text-muted-foreground uppercase tracking-wider text-center">Cancelled</th>
                                            <th class="px-4 pb-3.5 font-semibold text-xs text-muted-foreground uppercase tracking-wider text-center">Holiday</th>
                                            <th class="px-4 pb-3.5 font-semibold text-xs text-muted-foreground uppercase tracking-wider text-right">Attendance Rate</th>
                                        </tr>
                                    </thead>
                                    <tbody class="divide-y divide-outline-variant/50 text-sm">
                                        @foreach (var month in _summary.MonthlyAttendance)
                                        {
                                            <tr class="hover:bg-surface-variant/20 transition-colors text-on-surface-variant cursor-pointer" @onclick="() => NavigateToMonthly(month.Year, month.Month)">
                                                <td class="px-4 py-3.5 font-sans text-sm font-semibold text-foreground">@month.MonthName</td>
                                                <td class="px-4 py-3.5 text-center font-mono text-sm text-foreground">@month.TotalSessions</td>
                                                <td class="px-4 py-3.5 text-center font-mono text-sm text-primary font-bold">@month.Present</td>
                                                <td class="px-4 py-3.5 text-center font-mono text-sm text-error font-semibold">@month.Absent</td>
                                                <td class="px-4 py-3.5 text-center font-mono text-sm text-muted-foreground">@month.Cancelled</td>
                                                <td class="px-4 py-3.5 text-center font-mono text-sm text-muted-foreground">@month.Holiday</td>
                                                <td class="px-4 py-3.5 text-right">
                                                    <span class="px-2.5 py-1 rounded-full text-xs font-bold font-sans border @GetBadgeBorderAndBg(month.AttendanceRate)">
                                                        @month.AttendanceRate%
                                                    </span>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                        else
                        {
                            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
                                @foreach (var month in _summary.MonthlyAttendance)
                                {
                                    <div class="bg-card border border-border rounded-lg p-5 flex flex-col justify-between hover:border-primary/30 transition-all shadow-sm cursor-pointer" @onclick="() => NavigateToMonthly(month.Year, month.Month)">
                                        <div class="flex items-center justify-between mb-3">
                                            <h3 class="text-sm font-semibold text-foreground">@month.MonthName</h3>
                                            <span class="px-2.5 py-0.5 rounded-full text-[11px] font-bold font-sans border @GetBadgeBorderAndBg(month.AttendanceRate)">
                                                @month.AttendanceRate%
                                            </span>
                                        </div>
                                        <div class="grid grid-cols-2 gap-y-1.5 gap-x-4 text-xs font-mono text-muted-foreground border-t border-border/30 pt-3">
                                            <div>Total: <span class="text-foreground font-semibold">@month.TotalSessions</span></div>
                                            <div>Present: <span class="text-primary font-bold">@month.Present</span></div>
                                            <div>Absent: <span class="text-error font-semibold">@month.Absent</span></div>
                                            <div>Cancelled: <span class="text-foreground font-semibold">@month.Cancelled</span></div>
                                            <div>Holiday: <span class="text-foreground font-semibold">@month.Holiday</span></div>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    }
                }
                else if (_activeTab == Tab.Module)
                {
                    @if (_isLoadingModules)
                    {
                        <div class="flex justify-center items-center py-12">
                            <div class="animate-spin rounded-full h-8 w-8 border-b-2 border-primary"></div>
                        </div>
                    }
                    else
                    {
                        @if (_summary.ModuleAttendance == null || !_summary.ModuleAttendance.Any())
                        {
                            <div class="text-center text-muted-foreground font-sans text-sm py-6">
                                No module attendance records found for this semester.
                            </div>
                        }
                        else
                        {
                            @if (_breakdownViewMode == "table")
                            {
                                <div class="overflow-x-auto">
                                    <table class="w-full text-left border-collapse text-sm">
                                        <thead>
                                            <tr class="border-b border-outline-variant text-on-surface-variant">
                                                <th class="px-4 pb-3.5 font-semibold text-xs text-muted-foreground uppercase tracking-wider">Module</th>
                                                <th class="px-4 pb-3.5 font-semibold text-xs text-muted-foreground uppercase tracking-wider">Teacher</th>
                                                <th class="px-4 pb-3.5 font-semibold text-xs text-muted-foreground uppercase tracking-wider text-center">Total Sessions</th>
                                                <th class="px-4 pb-3.5 font-semibold text-xs text-muted-foreground uppercase tracking-wider text-center">Present</th>
                                                <th class="px-4 pb-3.5 font-semibold text-xs text-muted-foreground uppercase tracking-wider text-center">Absent</th>
                                                <th class="px-4 pb-3.5 font-semibold text-xs text-muted-foreground uppercase tracking-wider text-right">Attendance Rate</th>
                                            </tr>
                                        </thead>
                                        <tbody class="divide-y divide-outline-variant/50 text-sm">
                                            @foreach (var mod in _summary.ModuleAttendance)
                                            {
                                                <tr class="hover:bg-surface-variant/20 transition-colors text-on-surface-variant cursor-pointer" @onclick="() => NavigateToModule(mod.ModuleId)">
                                                    <td class="px-4 py-3.5 font-sans text-sm font-semibold text-primary hover:underline">@mod.ModuleName</td>
                                                    <td class="px-4 py-3.5 font-sans text-sm text-muted-foreground">@(string.IsNullOrEmpty(mod.TeacherName) ? "N/A" : mod.TeacherName)</td>
                                                    <td class="px-4 py-3.5 text-center font-mono text-sm text-foreground">@mod.TotalSessions</td>
                                                    <td class="px-4 py-3.5 text-center font-mono text-sm text-primary font-bold">@mod.TotalPresent</td>
                                                    <td class="px-4 py-3.5 text-center font-mono text-sm text-error font-semibold">@mod.TotalAbsent</td>
                                                    <td class="px-4 py-3.5 text-right">
                                                        <span class="px-2.5 py-1 rounded-full text-xs font-bold font-sans border @GetBadgeBorderAndBg(mod.AttendanceRate)">
                                                            @mod.AttendanceRate%
                                                        </span>
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            }
                            else
                            {
                                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
                                    @foreach (var mod in _summary.ModuleAttendance)
                                    {
                                        <div class="bg-card border border-border rounded-lg p-5 flex flex-col justify-between hover:border-primary/30 transition-all shadow-sm cursor-pointer" @onclick="() => NavigateToModule(mod.ModuleId)">
                                            <div class="flex items-start justify-between mb-3">
                                                <div>
                                                    <h3 class="text-sm font-semibold text-foreground hover:underline">@mod.ModuleName</h3>
                                                    <p class="text-[10px] text-muted-foreground font-sans mt-0.5">@(string.IsNullOrEmpty(mod.TeacherName) ? "N/A" : mod.TeacherName)</p>
                                                </div>
                                                <span class="px-2.5 py-0.5 rounded-full text-[11px] font-bold font-sans border @GetBadgeBorderAndBg(mod.AttendanceRate)">
                                                    @mod.AttendanceRate%
                                                </span>
                                            </div>
                                            <div class="grid grid-cols-2 gap-y-1.5 gap-x-4 text-xs font-mono text-muted-foreground border-t border-border/30 pt-3">
                                                <div>Total Classes: <span class="text-foreground font-semibold">@mod.TotalSessions</span></div>
                                                <div>Present: <span class="text-primary font-bold">@mod.TotalPresent</span></div>
                                                <div>Absent: <span class="text-error font-semibold">@mod.TotalAbsent</span></div>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                        }
                    }
                }
            </div>
        </div>
    }
}

@code {
    private enum Tab { Daily, Weekly, Monthly, Module }

    private bool _isLoadingSemesters = true;
    private bool _isLoadingSummary = true;
    private bool _isLoadingDailyWeekly = true;
    private bool _isLoadingModules = true;
    private bool _isError = false;
    private string _message = string.Empty;
    private List<SemesterDto>? _semesters;
    private DashboardSummaryDto? _summary;
    private long _selectedSemesterId;
    private long _currentSemesterId;
    private Tab _activeTab = Tab.Daily;
    private string _breakdownViewMode = "table";
    private int _weeklyPageNumber = 1;
    private const int _weeklyPageSize = 5;

    protected override async Task OnInitializedAsync()
    {
        await LoadInitialData();
    }

    private async Task LoadInitialData()
    {
        _isLoadingSemesters = true;
        _isError = false;
        _message = string.Empty;
        try
        {
            var semestersResult = await Http.GetFromJsonAsync<PagedResult<SemesterDto>>("api/semesters");
            if (semestersResult != null && semestersResult.IsSuccess && semestersResult.Data != null)
            {
                _semesters = semestersResult.Data.OrderByDescending(s => s.StartDate).ToList();

                if (_semesters.Any())
                {
                    // Detect current semester
                    var today = DateOnly.FromDateTime(DateTime.UtcNow.AddHours(6.5)); // Myanmar Time
                    var currentSemester = _semesters.FirstOrDefault(s => s.StartDate <= today && today <= s.EndDate);
                    
                    // Fallback to the latest started semester if none matches today
                    if (currentSemester == null)
                    {
                        currentSemester = _semesters.OrderByDescending(s => s.StartDate).First();
                    }

                    _currentSemesterId = currentSemester.Id;
                    _selectedSemesterId = _currentSemesterId;

                    await LoadDashboardSummary(_selectedSemesterId);
                }
            }
            else
            {
                _isError = true;
                _message = semestersResult?.Message ?? "Failed to retrieve semesters.";
            }
        }
        catch (Exception ex)
        {
            _message = ex.GetFriendlyErrorMessage("Error loading semesters");
            _isError = true;
        }
        finally
        {
            _isLoadingSemesters = false;
        }
    }

    private async Task LoadDashboardSummary(long semesterId)
    {
        _isLoadingSummary = true;
        _isLoadingDailyWeekly = true;
        _isLoadingModules = true;
        _weeklyPageNumber = 1;
        try
        {
            var summaryResult = await Http.GetFromJsonAsync<ApiResult<DashboardSummaryDto>>($"api/semesters/{semesterId}/dashboard/summary");
            if (summaryResult != null && summaryResult.IsSuccess)
            {
                _summary = summaryResult.Data;
                _isLoadingSummary = false;
                
                // Allow overall rate and cards to render immediately
                StateHasChanged();

                // Fire-and-forget calls to load breakdowns independently in background
                _ = LoadDailyWeeklyBreakdown(semesterId);
                _ = LoadModulesBreakdown(semesterId);
            }
            else
            {
                _summary = null;
                _isLoadingSummary = false;
                _isLoadingDailyWeekly = false;
                _isLoadingModules = false;
                _isError = true;
                _message = summaryResult?.Message ?? "Failed to load dashboard summary.";
            }
        }
        catch (Exception ex)
        {
            _summary = null;
            _isLoadingSummary = false;
            _isLoadingDailyWeekly = false;
            _isLoadingModules = false;
            _message = ex.GetFriendlyErrorMessage("Error loading dashboard summary");
            _isError = true;
        }
    }

    private async Task LoadDailyWeeklyBreakdown(long semesterId)
    {
        try
        {
            var result = await Http.GetFromJsonAsync<ApiResult<DashboardDailyWeeklyDto>>($"api/semesters/{semesterId}/dashboard/daily-weekly");
            if (result != null && result.IsSuccess && result.Data != null && _summary != null)
            {
                _summary.DailyAttendance = result.Data.DailyAttendance;
                _summary.WeeklyAttendance = result.Data.WeeklyAttendance;
                _summary.MonthlyAttendance = result.Data.MonthlyAttendance;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading daily-weekly breakdown: {ex.Message}");
        }
        finally
        {
            _isLoadingDailyWeekly = false;
            StateHasChanged();
        }
    }

    private async Task LoadModulesBreakdown(long semesterId)
    {
        try
        {
            var result = await Http.GetFromJsonAsync<ApiResult<List<ModuleAnalyticsDto>>>($"api/semesters/{semesterId}/dashboard/modules");
            if (result != null && result.IsSuccess && result.Data != null && _summary != null)
            {
                _summary.ModuleAttendance = result.Data;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading modules breakdown: {ex.Message}");
        }
        finally
        {
            _isLoadingModules = false;
            StateHasChanged();
        }
    }

    private async Task OnSemesterChanged(ChangeEventArgs e)
    {
        if (e.Value != null && long.TryParse(e.Value.ToString(), out long semesterId))
        {
            _selectedSemesterId = semesterId;
            await LoadDashboardSummary(_selectedSemesterId);
        }
    }

    private async Task SetActiveTab(Tab tab)
    {
        _activeTab = tab;
        await Task.Delay(50);
        try
        {
            await JS.InvokeVoidAsync("eval", "document.getElementById('attendance-breakdown')?.scrollIntoView({ behavior: 'smooth' });");
        }
        catch
        {
            // Fallback silently if JS interop is not ready yet
        }
    }

    private void NavigateToStatus(string status)
    {
        Navigation.NavigateTo($"/sessions?semesterId={_selectedSemesterId}&status={Uri.EscapeDataString(status)}");
    }

    private void NavigateToDaily(string dayOfWeekStr)
    {
        if (Enum.TryParse<DayOfWeek>(dayOfWeekStr, out var dayOfWeek))
        {
            Navigation.NavigateTo($"/sessions?semesterId={_selectedSemesterId}&dayOfWeek={(int)dayOfWeek}");
        }
    }

    private void NavigateToWeekly(DateOnly start, DateOnly end)
    {
        Navigation.NavigateTo($"/sessions?semesterId={_selectedSemesterId}&startDate={start.ToString("yyyy-MM-dd")}&endDate={end.ToString("yyyy-MM-dd")}");
    }

    private void NavigateToMonthly(int year, int month)
    {
        var start = new DateOnly(year, month, 1);
        var end = start.AddMonths(1).AddDays(-1);
        Navigation.NavigateTo($"/sessions?semesterId={_selectedSemesterId}&startDate={start.ToString("yyyy-MM-dd")}&endDate={end.ToString("yyyy-MM-dd")}");
    }

    private void NavigateToModule(long moduleId)
    {
        Navigation.NavigateTo($"/sessions?semesterId={_selectedSemesterId}&moduleId={moduleId}");
    }

    private string GetHealthColorClass(double rate)
    {
        if (rate >= 75) return "text-emerald-500";
        if (rate >= 60) return "text-amber-500";
        return "text-destructive";
    }

    private string GetHealthBgClass(double rate)
    {
        if (rate >= 75) return "bg-emerald-500";
        if (rate >= 60) return "bg-amber-500";
        return "bg-destructive";
    }

    private string GetBadgeBorderAndBg(double rate)
    {
        if (rate >= 75) return "border-emerald-500/20 text-emerald-500 bg-emerald-500/10";
        if (rate >= 60) return "border-amber-500/20 text-amber-500 bg-amber-500/10";
        return "border-destructive/20 text-destructive bg-destructive/10";
    }

    private RenderFragment RenderDashboardSkeletons => __builder =>
    {
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
            @for (int i = 0; i < 4; i++)
            {
                <div class="bg-card border border-border p-6 rounded-lg shadow-sm animate-pulse">
                    <div class="h-4 bg-muted rounded w-24 mb-3"></div>
                    <div class="h-8 bg-muted rounded w-12 text-transparent">0</div>
                </div>
            }
        </div>

        <div class="bg-card border border-border rounded-lg shadow-sm p-6 mb-8 animate-pulse">
            <div class="h-5 bg-muted rounded w-36 mb-4"></div>
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
                <div class="space-y-3">
                    <div class="h-4 bg-muted rounded w-full"></div>
                    <div class="h-4 bg-muted rounded w-5/6"></div>
                    <div class="h-20 bg-muted rounded w-full mt-4"></div>
                </div>
                <div class="border border-border rounded-md p-4 space-y-3 bg-background/30">
                    @for (int i = 0; i < 6; i++)
                    {
                        <div class="flex justify-between items-center">
                            <div class="h-3 bg-muted rounded w-1/3"></div>
                            <div class="h-3 bg-muted rounded w-12"></div>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="bg-card border border-border rounded-lg shadow-sm overflow-hidden mb-8 animate-pulse">
            <div class="border-b border-border bg-accent/20 flex p-1 gap-1">
                <div class="px-3 py-1.5 h-7 bg-muted rounded-md w-24"></div>
                <div class="px-3 py-1.5 h-7 bg-muted rounded-md w-24"></div>
                <div class="px-3 py-1.5 h-7 bg-muted rounded-md w-24"></div>
                <div class="px-3 py-1.5 h-7 bg-muted rounded-md w-24"></div>
            </div>
            <div class="p-6 space-y-4">
                <div class="flex gap-4 border-b border-border pb-3">
                    <div class="h-4 bg-muted rounded w-1/4"></div>
                    <div class="h-4 bg-muted rounded w-16 mx-auto"></div>
                    <div class="h-4 bg-muted rounded w-16 mx-auto"></div>
                    <div class="h-4 bg-muted rounded w-16 mx-auto"></div>
                    <div class="h-4 bg-muted rounded w-16 mx-auto"></div>
                </div>
                @for (int i = 0; i < 5; i++)
                {
                    <div class="flex gap-4 py-2 border-b border-border/50">
                        <div class="h-3 bg-muted rounded w-1/4"></div>
                        <div class="h-3 bg-muted rounded w-10 mx-auto"></div>
                        <div class="h-3 bg-muted rounded w-10 mx-auto"></div>
                        <div class="h-3 bg-muted rounded w-10 mx-auto"></div>
                        <div class="h-3 bg-muted rounded w-10 mx-auto"></div>
                    </div>
                }
            </div>
        </div>
    };

    private int GetWeeklyTotalPages()
    {
        if (_summary?.WeeklyAttendance == null || !_summary.WeeklyAttendance.Any()) return 1;
        return (int)Math.Ceiling((double)_summary.WeeklyAttendance.Count / _weeklyPageSize);
    }

    private void OnWeeklyPageChanged(int page)
    {
        _weeklyPageNumber = page;
    }
}
