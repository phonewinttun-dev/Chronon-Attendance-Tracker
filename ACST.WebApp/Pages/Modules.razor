                <button class="px-4 py-2 bg-destructive text-destructive-foreground rounded-md text-sm font-medium hover:bg-destructive/90 transition-colors focus:outline-none" @onclick="ConfirmConfirmDeleteModule">Delete</button>
            </div>
        </div>
