@if (_showDeleteModuleConfirm)
{
    <div class="fixed inset-0 bg-background/80 backdrop-blur-sm flex items-center justify-center z-50">
        <div class="bg-card border border-border rounded-lg p-6 max-w-sm w-full shadow-lg text-center animate-in fade-in zoom-in duration-200">
            <h3 class="text-lg font-bold text-foreground mb-2 text-center">Delete Module?</h3>
            <p class="text-sm text-muted-foreground mb-6 text-center">Are you sure you want to delete this module? This action will also delete all associated class sessions and timetables, and cannot be undone.</p>
            <div class="flex justify-center gap-3">
