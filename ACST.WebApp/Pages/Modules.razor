        <div class="bg-card border border-border rounded-lg p-6 max-w-sm w-full shadow-lg text-center animate-in fade-in zoom-in duration-200">
            <div class="mx-auto flex items-center justify-center h-12 w-12 rounded-full bg-destructive/10 text-destructive mb-4">
                <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                </svg>
            </div>
            <h3 class="text-base font-bold text-foreground mb-2">Deletion Failed</h3>
            <p class="text-xs text-muted-foreground mb-5">@_message</p>
            <button class="w-full py-2 bg-secondary text-foreground hover:bg-muted border border-border rounded-md text-xs font-semibold transition-colors focus:outline-none"
                    @onclick="CloseScheduleDeleteFailure">
                Close
