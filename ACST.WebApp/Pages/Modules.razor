                <button class="px-4 py-2 border border-input rounded-md text-sm font-medium text-foreground hover:bg-muted transition-colors focus:outline-none" @onclick="CancelDeleteSchedule">Cancel</button>
                <button class="px-4 py-2 bg-destructive text-destructive-foreground rounded-md text-sm font-medium hover:bg-destructive/90 transition-colors focus:outline-none" @onclick="ConfirmDeleteSchedule">Delete</button>
