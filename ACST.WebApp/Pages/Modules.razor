    private async Task ConfirmDeleteSchedule()
    {
        var id = _scheduleIdToDelete;
        CancelDeleteSchedule();
        
        _message = string.Empty;
        _isDeletingSchedule = true;
        StateHasChanged();
        try
        {
            var response = await Http.DeleteAsync($"api/recurring-schedules/{id}");
            _isDeletingSchedule = false;
            if (response.IsSuccessStatusCode)
            {
                _showScheduleDeleteSuccess = true;
                await LoadData();
            }
            else
            {
                var errorMsg = await response.Content.ReadAsStringAsync();
                _message = errorMsg.Contains("Recurring schedule not found") 
                    ? "This timetable has already been deleted or could not be found." 
                    : "Failed to delete timetable. Please try again.";
                _isError = true;
                _showScheduleDeleteFailure = true;
            }
        }
        catch (Exception ex)
        {
            _isDeletingSchedule = false;
            _message = "An error occurred while deleting the timetable.";
            _isError = true;
            _showScheduleDeleteFailure = true;
        }
    }

