@page "/modules"
@using ACST.WebApp.Models
@inject HttpClient Http

<PageTitle>Modules</PageTitle>

<div class="flex justify-between items-center mb-8">
    <h1 class="text-2xl font-bold tracking-tight text-foreground">Modules</h1>
    <div class="flex items-center gap-3">
        <div class="flex items-center gap-1 bg-muted border border-border p-1 rounded-md">
            <button class="p-1.5 rounded transition-all @(_viewMode == "table" ? "bg-card text-foreground shadow-sm" : "text-muted-foreground hover:text-foreground")" 
                    @onclick='() => _viewMode = "table"' 
                    title="Table View">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-list"><line x1="8" x2="21" y1="6" y2="6"/><line x1="8" x2="21" y1="12" y2="12"/><line x1="8" x2="21" y1="18" y2="18"/><line x1="3" x2="3.01" y1="6" y2="6"/><line x1="3" x2="3.01" y1="12" y2="12"/><line x1="3" x2="3.01" y1="18" y2="18"/></svg>
            </button>
            <button class="p-1.5 rounded transition-all @(_viewMode == "card" ? "bg-card text-foreground shadow-sm" : "text-muted-foreground hover:text-foreground")" 
                    @onclick='() => _viewMode = "card"' 
                    title="Card View">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-layout-grid"><rect width="7" height="7" x="3" y="3" rx="1"/><rect width="7" height="7" x="14" y="3" rx="1"/><rect width="7" height="7" x="14" y="14" rx="1"/><rect width="7" height="7" x="3" y="14" rx="1"/></svg>
            </button>
        </div>
        <button class="bg-primary text-primary-foreground hover:bg-primary/90 px-4 py-2 rounded-md text-sm font-semibold transition-all" @onclick="ToggleCreateForm">
            @(_showCreateForm ? "Cancel" : "New Module")
        </button>
    </div>
</div>

<div class="flex flex-wrap items-center gap-3 mb-6 bg-card border border-border p-4 rounded-lg shadow-sm">
    <!-- Search Box -->
    <div class="flex-1 min-w-[240px] flex flex-col gap-1">
        <label class="text-[10px] font-bold text-muted-foreground uppercase tracking-wider font-sans">Search Modules</label>
        <div class="relative flex items-center">
            <input type="text" 
                   class="w-full pl-9 pr-24 py-2.5 bg-background border border-border rounded-md text-foreground text-xs focus:outline-none focus:ring-1 focus:ring-ring transition-all placeholder:text-muted-foreground" 
                   placeholder="Search by module name or code" 
                   @bind="_searchTerm" 
                   @onkeyup="OnSearchKeyUp" />
            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none text-muted-foreground">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-search"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
            </div>
            @if (!string.IsNullOrEmpty(_searchTerm))
            {
                <button class="absolute right-[76px] text-muted-foreground hover:text-foreground text-xs focus:outline-none" @onclick="ClearSearch" title="Clear search">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-x"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                </button>
            }
            <button class="absolute right-0 top-0 bottom-0 px-4 bg-primary text-primary-foreground hover:bg-primary/90 rounded-r-md text-xs font-semibold transition-all focus:outline-none" @onclick="TriggerSearch">
                Search
            </button>
        </div>
    </div>

    <!-- Semester Filter -->
    <div class="flex flex-col gap-1 min-w-[200px]">
        <label class="text-[10px] font-bold text-muted-foreground uppercase tracking-wider font-sans">Semester</label>
        <select class="p-2.5 bg-background border border-border rounded-md text-foreground font-sans text-xs focus:outline-none focus:ring-1 focus:ring-ring w-full"
                value="@_selectedFilterSemesterIdStr" @onchange="OnSemesterFilterChanged">
            <option value="">All Semesters</option>
            @if (_semesters != null)
            {
                @foreach (var sem in _semesters)
                {
                    <option value="@sem.Id">@sem.Name</option>
                }
            }
        </select>
    </div>
</div>


@if (!string.IsNullOrEmpty(_message))
{
    <div class="border p-4 rounded-lg mb-6 text-sm font-semibold flex items-center justify-between gap-3 transition-all @(_isError ? "bg-destructive/10 border-destructive/30 text-destructive" : "bg-emerald-500/10 border-emerald-500/20 text-emerald-500")">
        <div class="flex items-center gap-2.5">
            @if (_isError)
            {
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 shrink-0"><circle cx="12" cy="12" r="10"/><line x1="12" x2="12" y1="8" y2="12"/><line x1="12" x2="12.01" y1="16" y2="16"/></svg>
            }
            else
            {
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 shrink-0"><path d="M20 6 9 17l-5-5"/></svg>
            }
            <span>@_message</span>
        </div>
        <button class="hover:opacity-80 focus:outline-none text-base font-bold px-1.5 py-0.5 rounded hover:bg-foreground/5 transition-all" @onclick="() => _message = string.Empty" title="Dismiss">×</button>
    </div>
}

@if (_showCreateForm)
{
    <div class="bg-card border border-border p-6 rounded-lg shadow-sm mb-8">
        <h2 class="text-base font-bold mb-4 text-foreground tracking-tight">Create New Module</h2>
        
        <div class="grid grid-cols-1 md:grid-cols-4 gap-4 mb-6">
            <div>
                <label class="block text-sm font-semibold text-muted-foreground mb-1">Module Name</label>
                <input type="text" class="w-full p-2.5 bg-background border border-border rounded-md text-foreground focus:outline-none focus:ring-1 focus:ring-ring" @bind="_newModule.Name" placeholder="e.g. Introduction to CS" />
            </div>
            <div>
                <label class="block text-sm font-semibold text-muted-foreground mb-1">Module Code</label>
                <input type="text" class="w-full p-2.5 bg-background border border-border rounded-md text-foreground focus:outline-none focus:ring-1 focus:ring-ring" @bind="_newModule.ModuleCode" placeholder="e.g. CS-101" />
            </div>
            <div>
                <label class="block text-sm font-semibold text-muted-foreground mb-1">Teacher Name</label>
                <input type="text" class="w-full p-2.5 bg-background border border-border rounded-md text-foreground focus:outline-none focus:ring-1 focus:ring-ring" @bind="_newModule.TeacherName" placeholder="e.g. John Doe" />
            </div>
            <div>
                <label class="block text-sm font-semibold text-muted-foreground mb-1">Semester</label>
                <select class="w-full p-2.5 bg-background border border-border rounded-md text-foreground focus:outline-none focus:ring-1 focus:ring-ring" @bind="_newModuleSemesterIdStr">
                    <option value="">Select Semester (Optional)...</option>
                    @if (_semesters != null)
                    {
                        @foreach(var sem in _semesters)
                        {
                            <option value="@sem.Id">@sem.Name</option>
                        }
                    }
                </select>
            </div>
        </div>

        <div class="mt-6 border-t border-border pt-4 mb-6">
            <h3 class="text-sm font-bold text-foreground mb-4">Schedules</h3>
            
            @if (!_newModuleSchedules.Any())
            {
                <p class="text-xs text-muted-foreground italic mb-4">No schedules added yet. Click the button below to add a schedule.</p>
            }
            else
            {
                <div class="space-y-3 mb-4">
                    @for (int i = 0; i < _newModuleSchedules.Count; i++)
                    {
                        var index = i;
                        var sch = _newModuleSchedules[i];
                        <div class="grid grid-cols-1 md:grid-cols-4 gap-4 items-end bg-muted/20 p-3 rounded-lg border border-border">
                            <div>
                                <label class="block text-xs font-semibold text-muted-foreground mb-1">Day of Week</label>
                                <select class="w-full p-2 bg-background border border-border rounded-md text-foreground text-xs focus:outline-none focus:ring-1 focus:ring-ring" 
                                        @bind="sch.DayOfWeek">
                                    <option value="1">Monday</option>
                                    <option value="2">Tuesday</option>
                                    <option value="3">Wednesday</option>
                                    <option value="4">Thursday</option>
                                    <option value="5">Friday</option>
                                    <option value="6">Saturday</option>
                                    <option value="0">Sunday</option>
                                </select>
                            </div>
                            <div>
                                <label class="block text-xs font-semibold text-muted-foreground mb-1">Start Time</label>
                                <input type="time" class="w-full p-2 bg-background border border-border rounded-md text-foreground text-xs font-mono focus:outline-none focus:ring-1 focus:ring-ring" 
                                       @bind="sch.StartTime" />
                            </div>
                            <div>
                                <label class="block text-xs font-semibold text-muted-foreground mb-1">End Time</label>
                                <input type="time" class="w-full p-2 bg-background border border-border rounded-md text-foreground text-xs font-mono focus:outline-none focus:ring-1 focus:ring-ring" 
                                       @bind="sch.EndTime" />
                            </div>
                            <div class="flex justify-end">
                                <button type="button" class="bg-destructive/10 hover:bg-destructive hover:text-destructive-foreground text-destructive px-3 py-2 rounded-md text-xs font-semibold transition-all w-full md:w-auto" 
                                        @onclick="() => RemoveNewModuleSchedule(index)">
                                    Remove
                                </button>
                            </div>
                        </div>
                    }
                </div>
            }
            
            <button type="button" class="bg-secondary text-foreground hover:bg-secondary/80 border border-border px-3 py-2 rounded-md text-xs font-semibold transition-all shadow-sm" 
                    @onclick="AddNewModuleSchedule">
                + Add Schedule
            </button>
        </div>

        <div class="flex items-center gap-3">
            <button class="bg-primary text-primary-foreground hover:bg-primary/90 px-4 py-2 rounded-md text-sm font-semibold transition-all disabled:opacity-50 shadow-sm" @onclick="OnCreateModuleClicked" disabled="@_isSubmitting">
                @(_isSubmitting ? "Creating..." : "Create Module")
            </button>
            @if (_newModuleSchedules.Any())
            {
                <button type="button" class="bg-primary text-primary-foreground hover:bg-primary/90 px-4 py-2 rounded-md text-sm font-semibold transition-all disabled:opacity-50 shadow-sm" @onclick="OnGenerateSessionsClicked" disabled="@_isSubmitting">
                    Generate Sessions
                </button>
            }
        </div>
    </div>
}

<!-- Assign Schedule Form -->
@if (_selectedModuleId > 0)
{
    <div class="bg-card border border-primary p-6 rounded-lg shadow-sm mb-8">
        <div class="flex justify-between items-center mb-4">
            <h2 class="text-base font-bold text-foreground tracking-tight">Add Schedule to @_selectedModuleName</h2>
            <button class="text-muted-foreground hover:text-foreground text-sm font-semibold" @onclick="CancelScheduleForm">Cancel</button>
        </div>

        <!-- Existing Schedules -->
        @if (_selectedModule != null && _selectedModule.Schedules != null && _selectedModule.Schedules.Any())
        {
            <div class="mb-6 p-4 bg-muted/20 border border-border rounded-md">
                <h3 class="text-xs font-bold text-muted-foreground uppercase tracking-wider mb-2 font-sans">Existing Timetables</h3>
                <div class="flex flex-wrap gap-2">
                    @foreach (var schedule in _selectedModule.Schedules)
                    {
                        <span class="inline-flex items-center gap-1.5 px-2 py-1 bg-card border border-border text-foreground rounded font-mono text-[10px]">
                            Semester: @schedule.SemesterName • @GetDayOfWeekName(schedule.DayOfWeek) @FormatTime(schedule.StartTime)-@FormatTime(schedule.EndTime)
                            <button class="text-destructive hover:text-destructive/80 font-bold focus:outline-none ml-1 text-sm leading-none" @onclick="() => OpenDeleteScheduleConfirm(schedule.Id)" @onclick:stopPropagation>×</button>
                        </span>
                    }
                </div>
            </div>
        }
        
        <div class="mb-6">
            <label class="block text-sm font-semibold text-muted-foreground mb-1">Semester</label>
            <select class="w-full p-2.5 bg-background border border-border rounded-md text-foreground focus:outline-none focus:ring-1 focus:ring-ring" @bind="_selectedSemesterId">
                <option value="0">Select Semester...</option>
                @if (_semesters != null)
                {
                    @foreach(var sem in _semesters)
                    {
                        <option value="@sem.Id">@sem.Name</option>
                    }
                }
            </select>
        </div>

        <div class="mb-6">
            <label class="block text-sm font-semibold text-muted-foreground mb-3">Schedules to Add</label>
            
            @if (!_assignSchedules.Any())
            {
                <p class="text-xs text-muted-foreground italic mb-4">No schedules added yet. Click the button below to add a schedule.</p>
            }
            else
            {
                <div class="space-y-3 mb-4">
                    @for (int i = 0; i < _assignSchedules.Count; i++)
                    {
                        var index = i;
                        var sch = _assignSchedules[i];
                        <div class="grid grid-cols-1 md:grid-cols-4 gap-4 items-end bg-muted/20 p-3 rounded-lg border border-border">
                            <div>
                                <label class="block text-xs font-semibold text-muted-foreground mb-1">Day of Week</label>
                                <select class="w-full p-2 bg-background border border-border rounded-md text-foreground text-xs focus:outline-none focus:ring-1 focus:ring-ring" 
                                        @bind="sch.DayOfWeek">
                                    <option value="1">Monday</option>
                                    <option value="2">Tuesday</option>
                                    <option value="3">Wednesday</option>
                                    <option value="4">Thursday</option>
                                    <option value="5">Friday</option>
                                    <option value="6">Saturday</option>
                                    <option value="0">Sunday</option>
                                </select>
                            </div>
                            <div>
                                <label class="block text-xs font-semibold text-muted-foreground mb-1">Start Time</label>
                                <input type="time" class="w-full p-2 bg-background border border-border rounded-md text-foreground text-xs font-mono focus:outline-none focus:ring-1 focus:ring-ring" 
                                       @bind="sch.StartTime" />
                            </div>
                            <div>
                                <label class="block text-xs font-semibold text-muted-foreground mb-1">End Time</label>
                                <input type="time" class="w-full p-2 bg-background border border-border rounded-md text-foreground text-xs font-mono focus:outline-none focus:ring-1 focus:ring-ring" 
                                       @bind="sch.EndTime" />
                            </div>
                            <div class="flex justify-end">
                                <button type="button" class="bg-destructive/10 hover:bg-destructive hover:text-destructive-foreground text-destructive px-3 py-2 rounded-md text-xs font-semibold transition-all w-full md:w-auto" 
                                        @onclick="() => RemoveAssignSchedule(index)">
                                    Remove
                                </button>
                            </div>
                        </div>
                    }
                </div>
            }
            
            <button type="button" class="bg-secondary text-foreground hover:bg-secondary/80 border border-border px-3 py-2 rounded-md text-xs font-semibold transition-all shadow-sm" 
                    @onclick="AddAssignSchedule">
                + Add Schedule
            </button>
        </div>

        @if (_selectedSemester != null)
        {
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6 p-4 bg-muted/40 border border-border rounded-md">
                <div>
                    <label class="block text-xs font-semibold text-muted-foreground uppercase tracking-wider mb-1 font-sans">Semester Start Date</label>
                    <DatePicker Value="@_selectedSemester.StartDate" ValueChanged="((val) => {})" />
                </div>
                <div>
                    <label class="block text-xs font-semibold text-muted-foreground uppercase tracking-wider mb-1 font-sans">Semester End Date</label>
                    <DatePicker Value="@_selectedSemester.EndDate" ValueChanged="((val) => {})" />
                </div>
            </div>
        }

        <button class="bg-primary text-primary-foreground hover:bg-primary/90 px-4 py-2 rounded-md text-sm font-semibold transition-all disabled:opacity-50 shadow-sm" @onclick="CreateSchedule" disabled="@_isSubmittingSchedule">
            @(_isSubmittingSchedule ? "Adding..." : "Add Schedules")
        </button>
    </div>
}

@if (_showEditForm && _editingModuleId > 0)
{
    <div class="bg-card border border-primary p-6 rounded-lg shadow-sm mb-8">
        <div class="flex justify-between items-center mb-4">
            <div class="flex items-center gap-2">
                <button class="p-1.5 rounded-md hover:bg-muted text-muted-foreground hover:text-foreground transition-all focus:outline-none" 
                        @onclick="CancelEditForm" title="Back to Modules">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-arrow-left"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
                </button>
                <h2 class="text-base font-bold text-foreground tracking-tight">Edit Module</h2>
            </div>
            <button class="text-muted-foreground hover:text-foreground text-sm font-semibold" @onclick="CancelEditForm">Cancel</button>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-4 gap-4 mb-6">
            <div>
                <label class="block text-sm font-semibold text-muted-foreground mb-1">Module Name</label>
                <input type="text" class="w-full p-2.5 bg-background border border-border rounded-md text-foreground focus:outline-none focus:ring-1 focus:ring-ring" @bind="_editModule.Name" placeholder="e.g. Introduction to CS" />
            </div>
            <div>
                <label class="block text-sm font-semibold text-muted-foreground mb-1">Module Code</label>
                <input type="text" class="w-full p-2.5 bg-background border border-border rounded-md text-foreground focus:outline-none focus:ring-1 focus:ring-ring" @bind="_editModule.ModuleCode" placeholder="e.g. CS-101" />
            </div>
            <div>
                <label class="block text-sm font-semibold text-muted-foreground mb-1">Teacher Name</label>
                <input type="text" class="w-full p-2.5 bg-background border border-border rounded-md text-foreground focus:outline-none focus:ring-1 focus:ring-ring" @bind="_editModule.TeacherName" placeholder="e.g. John Doe" />
            </div>
            <div>
                <label class="block text-sm font-semibold text-muted-foreground mb-1">Semester</label>
                <select class="w-full p-2.5 bg-background border border-border rounded-md text-foreground focus:outline-none focus:ring-1 focus:ring-ring" @bind="_editModuleSemesterIdStr">
                    <option value="">Select Semester (Optional)...</option>
                    @if (_semesters != null)
                    {
                        @foreach(var sem in _semesters)
                        {
                            <option value="@sem.Id">@sem.Name</option>
                        }
                    }
                </select>
            </div>
        </div>

        <div class="mt-6 border-t border-border pt-4 mb-6">
            <h3 class="text-sm font-bold text-foreground mb-4">Schedules</h3>
            
            @if (!_editModuleSchedules.Any())
            {
                <p class="text-xs text-muted-foreground italic mb-4">No schedules added yet. Click the button below to add a schedule.</p>
            }
            else
            {
                <div class="space-y-3 mb-4">
                    @for (int i = 0; i < _editModuleSchedules.Count; i++)
                    {
                        var index = i;
                        var sch = _editModuleSchedules[i];
                        <div class="grid grid-cols-1 md:grid-cols-4 gap-4 items-end bg-muted/20 p-3 rounded-lg border border-border">
                            <div>
                                <label class="block text-xs font-semibold text-muted-foreground mb-1">Day of Week</label>
                                <select class="w-full p-2 bg-background border border-border rounded-md text-foreground text-xs focus:outline-none focus:ring-1 focus:ring-ring" 
                                        @bind="sch.DayOfWeek">
                                    <option value="1">Monday</option>
                                    <option value="2">Tuesday</option>
                                    <option value="3">Wednesday</option>
                                    <option value="4">Thursday</option>
                                    <option value="5">Friday</option>
                                    <option value="6">Saturday</option>
                                    <option value="0">Sunday</option>
                                </select>
                            </div>
                            <div>
                                <label class="block text-xs font-semibold text-muted-foreground mb-1">Start Time</label>
                                <input type="time" class="w-full p-2 bg-background border border-border rounded-md text-foreground text-xs font-mono focus:outline-none focus:ring-1 focus:ring-ring" 
                                       @bind="sch.StartTime" />
                            </div>
                            <div>
                                <label class="block text-xs font-semibold text-muted-foreground mb-1">End Time</label>
                                <input type="time" class="w-full p-2 bg-background border border-border rounded-md text-foreground text-xs font-mono focus:outline-none focus:ring-1 focus:ring-ring" 
                                       @bind="sch.EndTime" />
                            </div>
                            <div class="flex justify-end">
                                <button type="button" class="bg-destructive/10 hover:bg-destructive hover:text-destructive-foreground text-destructive px-3 py-2 rounded-md text-xs font-semibold transition-all w-full md:w-auto" 
                                        @onclick="() => RemoveEditModuleSchedule(index)">
                                    Remove
                                </button>
                            </div>
                        </div>
                    }
                </div>
            }
            
            <button type="button" class="bg-secondary text-foreground hover:bg-secondary/80 border border-border px-3 py-2 rounded-md text-xs font-semibold transition-all" 
                    @onclick="AddEditModuleSchedule">
                + Add Schedule
            </button>
        </div>

        <button class="bg-primary text-primary-foreground hover:bg-primary/90 px-4 py-2 rounded-md text-sm font-semibold transition-all disabled:opacity-50 shadow-sm" @onclick="UpdateModule" disabled="@_isSubmittingEdit">
            @(_isSubmittingEdit ? "Saving..." : "Save Changes")
        </button>
    </div>
}

@if (!_showCreateForm && !_showEditForm && _selectedModuleId == 0)
{
    @if (_viewMode == "table")
    {
        <div class="bg-card border border-border rounded-lg shadow-sm overflow-hidden">
            @if (_isLoading)
            {
                <div class="overflow-x-auto">
                    <table class="w-full text-left border-collapse text-sm animate-pulse">
                        <thead>
                            <tr class="border-b border-border bg-muted/50">
                                <th class="px-4 py-3.5 font-semibold text-muted-foreground uppercase tracking-wider">Module</th>
                                <th class="px-4 py-3.5 font-semibold text-muted-foreground uppercase tracking-wider">Teacher</th>
                                <th class="px-4 py-3.5 font-semibold text-muted-foreground uppercase tracking-wider">Semester</th>
                                <th class="px-4 py-3.5 font-semibold text-muted-foreground uppercase tracking-wider font-sans">Timetables</th>
                                <th class="px-4 py-3.5 font-semibold text-muted-foreground uppercase tracking-wider">Attendance</th>
                                <th class="px-4 py-3.5 font-semibold text-muted-foreground uppercase tracking-wider">Actions</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-border">
                            @for (int i = 0; i < 6; i++)
                            {
                                <tr>
                                    <td class="px-4 py-4">
                                        <div class="h-3 bg-muted rounded w-20"></div>
                                    </td>
                                    <td class="px-4 py-4">
                                        <div class="h-3 bg-muted rounded w-28"></div>
                                    </td>
                                    <td class="px-4 py-4">
                                        <div class="h-3 bg-muted rounded w-24"></div>
                                    </td>
                                    <td class="px-4 py-4">
                                        <div class="h-3 bg-muted rounded w-24"></div>
                                    </td>
                                    <td class="px-4 py-4">
                                        <div class="h-4 bg-muted rounded w-16"></div>
                                    </td>
                                    <td class="px-4 py-4">
                                        <div class="flex gap-2">
                                            <div class="h-7 bg-muted rounded w-24"></div>
                                            <div class="h-7 bg-muted rounded w-16"></div>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else if (_modules == null || !_modules.Any())
            {
                <div class="p-6 text-muted-foreground text-sm">No modules found. Create one to get started.</div>
            }
            else
            {
                <table class="w-full text-left border-collapse text-sm">
                    <thead>
                        <tr class="border-b border-border bg-muted/50">
                            <th class="px-4 py-3.5 font-semibold text-muted-foreground uppercase tracking-wider">Module</th>
                            <th class="px-4 py-3.5 font-semibold text-muted-foreground uppercase tracking-wider">Teacher</th>
                            <th class="px-4 py-3.5 font-semibold text-muted-foreground uppercase tracking-wider">Semester</th>
                            <th class="px-4 py-3.5 font-semibold text-muted-foreground uppercase tracking-wider font-sans">Timetables</th>
                            <th class="px-4 py-3.5 font-semibold text-muted-foreground uppercase tracking-wider">Attendance</th>
                            <th class="px-4 py-3.5 font-semibold text-muted-foreground uppercase tracking-wider">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-border">
                        @foreach (var mod in _modules)
                        {
                            <tr class="hover:bg-accent/40 transition-colors">
                                <td class="px-4 py-3.5 font-semibold text-foreground">
                                    <div>@mod.Name</div>
                                    <div class="text-[10px] text-muted-foreground font-mono mt-0.5">@mod.ModuleCode</div>
                                </td>
                                <td class="px-4 py-3.5 text-muted-foreground">@mod.TeacherName</td>
                                <td class="px-4 py-3.5 text-muted-foreground">@(string.IsNullOrEmpty(mod.SemesterName) ? "None" : mod.SemesterName)</td>
                                <td class="px-4 py-3.5 text-muted-foreground">
                                    @if (mod.Schedules != null && mod.Schedules.Any())
                                    {
                                        <div class="flex flex-col gap-1">
                                            @foreach (var schedule in mod.Schedules)
                                            {
                                                <div class="inline-flex items-center gap-1.5 bg-muted/40 border border-border px-1.5 py-0.5 rounded text-[11px] text-muted-foreground font-mono w-max">
                                                    <span>@GetDayOfWeekName(schedule.DayOfWeek): @FormatTime(schedule.StartTime) - @FormatTime(schedule.EndTime)</span>
                                                    <button class="text-destructive hover:text-destructive/80 font-bold focus:outline-none" @onclick="() => OpenDeleteScheduleConfirm(schedule.Id)" @onclick:stopPropagation>×</button>
                                                </div>
                                            }
                                        </div>
                                    }
                                    else
                                    {
                                        <span class="text-muted-foreground text-xs italic">No schedule</span>
                                    }
                                </td>
                                <td class="px-4 py-3.5">
                                    @if (mod.TotalValidSessions > 0)
                                    {
                                        <div class="flex items-center gap-2">
                                            <span class="px-2.5 py-0.5 rounded-full text-[11px] font-bold font-sans border @GetBadgeBorderAndBg(mod.AttendanceRate)">
                                                @mod.AttendanceRate%
                                            </span>
                                            <span class="text-muted-foreground text-[10px] font-mono">(@mod.PresentSessions/@mod.TotalValidSessions)</span>
                                        </div>
                                    }
                                    else
                                    {
                                        <span class="text-muted-foreground font-mono">-</span>
                                    }
                                </td>
                                <td class="px-4 py-3.5 whitespace-nowrap">
                                    <div class="flex items-center gap-2">
                                        <button class="text-primary hover:bg-primary/10 border border-primary/20 px-3 py-1 rounded transition-all text-xs font-semibold" @onclick="() => OpenScheduleForm(mod)">Add Schedule</button>
                                        <button class="text-primary hover:bg-primary/10 border border-primary/20 px-3 py-1 rounded transition-all text-xs font-semibold" @onclick="() => OpenEditForm(mod)">Edit</button>
                                        <button class="text-destructive hover:bg-destructive/10 border border-destructive/20 px-3 py-1 rounded transition-all text-xs font-semibold disabled:opacity-50" 
                                                @onclick="() => RequestDeleteModule(mod.Id)" 
                                                disabled="@_deletingModuleIds.Contains(mod.Id)">
                                            @(_deletingModuleIds.Contains(mod.Id) ? "Deleting..." : "Delete")
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
                <div class="border-t border-border bg-card">
                    <PaginationControl PageNumber="@_pageNumber" TotalPages="@_totalPages" PageChanged="OnPageChanged" />
                </div>
            }
        </div>
    }
    else
    {
        @if (_isLoading)
        {
            <div class="flex flex-wrap justify-center gap-4 animate-pulse">
                @for (int i = 0; i < 6; i++)
                {
                    <div class="bg-card border border-border rounded-lg p-5 flex flex-col justify-between shadow-sm w-full md:w-[calc(50%-0.5rem)] lg:w-[calc(33.333%-0.75rem)] flex-grow max-w-[400px]">
                        <div>
                            <div class="flex justify-between items-start mb-3">
                                <div class="h-4 bg-muted rounded w-24"></div>
                                <div class="h-4 bg-muted rounded w-20"></div>
                            </div>
                            <div class="h-3 bg-muted rounded w-28 mb-4"></div>
                        </div>
                        <div class="flex gap-2 border-t border-border pt-4 mt-2">
                            <div class="h-7 bg-muted rounded flex-1"></div>
                            <div class="h-7 bg-muted rounded w-12"></div>
                            <div class="h-7 bg-muted rounded w-16"></div>
                        </div>
                    </div>
                }
            </div>
        }
        else if (_modules == null || !_modules.Any())
        {
            <div class="bg-card border border-border rounded-lg shadow-sm p-6 text-muted-foreground text-sm">No modules found. Create one to get started.</div>
        }
        else
        {
            <div class="flex flex-wrap justify-center gap-4">
                @foreach (var mod in _modules)
                {
                    <div class="bg-card border border-border rounded-lg p-5 flex flex-col justify-between hover:border-primary/50 transition-all shadow-sm w-full md:w-[calc(50%-0.5rem)] lg:w-[calc(33.333%-0.75rem)] flex-grow max-w-[400px]">
                        <div>
                            <div class="flex justify-between items-start mb-3">
                                <div>
                                    <div class="flex items-center gap-1.5">
                                        <span class="px-1.5 py-0.5 text-[9px] font-mono font-bold bg-secondary border border-border text-foreground rounded">@mod.ModuleCode</span>
                                        <h3 class="text-base font-bold text-foreground tracking-tight">@mod.Name</h3>
                                    </div>
                                    <div class="flex items-center gap-2 text-xs text-muted-foreground mt-1 font-mono">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-user"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                                        <span>@mod.TeacherName</span>
                                    </div>
                                </div>
                                <div class="flex flex-col items-end gap-1.5 shrink-0">
                                    <span class="px-2.5 py-0.5 text-[10px] font-semibold uppercase tracking-wider rounded-full @(string.IsNullOrEmpty(mod.SemesterName) ? "bg-muted text-muted-foreground border border-border" : "bg-primary/10 text-primary border border-primary/20")">
                                        @(string.IsNullOrEmpty(mod.SemesterName) ? "No Semester" : mod.SemesterName)
                                    </span>
                                    @if (mod.TotalValidSessions > 0)
                                    {
                                        <span class="px-2.5 py-0.5 rounded-full text-[11px] font-bold font-sans border @GetBadgeBorderAndBg(mod.AttendanceRate)">
                                            @mod.AttendanceRate%
                                        </span>
                                    }
                                </div>
                            </div>
                            
                            <!-- Attendance Metrics -->
                            @if (mod.TotalValidSessions > 0)
                            {
                                <div class="grid grid-cols-2 gap-y-1.5 gap-x-4 text-xs font-mono text-muted-foreground border-t border-border/30 pt-3 mb-4">
                                    <div>Total Valid: <span class="text-foreground font-semibold">@mod.TotalValidSessions</span></div>
                                    <div>Present: <span class="text-primary font-bold">@mod.PresentSessions</span></div>
                                    <div>Absent: <span class="text-error font-semibold">@(mod.TotalValidSessions - mod.PresentSessions)</span></div>
                                </div>
                            }
                            else
                            {
                                <div class="mb-4 text-xs text-muted-foreground italic border-t border-border/30 pt-3">
                                    No sessions scheduled.
                                </div>
                            }

                            <!-- Timetables / Schedules -->
                            <div class="border-t border-border/30 pt-3 mb-4">
                                <label class="block text-[10px] font-bold text-muted-foreground uppercase tracking-wider mb-1.5">Timetables</label>
                                @if (mod.Schedules != null && mod.Schedules.Any())
                                {
                                    <div class="flex flex-wrap gap-1.5">
                                        @foreach (var schedule in mod.Schedules)
                                        {
                                            <span class="inline-flex items-center gap-1.5 px-2 py-0.5 bg-muted text-muted-foreground border border-border rounded font-mono text-xs">
                                                @GetDayOfWeekName(schedule.DayOfWeek) @FormatTime(schedule.StartTime)-@FormatTime(schedule.EndTime)
                                                <button class="text-destructive hover:text-destructive/80 font-bold focus:outline-none" @onclick="() => OpenDeleteScheduleConfirm(schedule.Id)" @onclick:stopPropagation>×</button>
                                            </span>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <span class="text-muted-foreground text-xs italic">No schedule assigned</span>
                                }
                            </div>
                        </div>
                        <div class="flex gap-2 border-t border-border pt-4 mt-2">
                            <button class="flex-1 text-center bg-secondary hover:bg-secondary/80 text-foreground border border-border py-1.5 rounded text-xs font-semibold transition-all" @onclick="() => OpenScheduleForm(mod)">Add Schedule</button>
                            <button class="text-center hover:bg-accent/40 text-foreground border border-border px-3 py-1.5 rounded text-xs font-semibold transition-all" @onclick="() => OpenEditForm(mod)">Edit</button>
                            <button class="text-center bg-destructive/10 hover:bg-destructive text-destructive hover:text-white border border-destructive/20 px-3 py-1.5 rounded text-xs font-semibold transition-all disabled:opacity-50" 
                                    @onclick="() => RequestDeleteModule(mod.Id)" 
                                    disabled="@_deletingModuleIds.Contains(mod.Id)">
                                @(_deletingModuleIds.Contains(mod.Id) ? "Deleting..." : "Delete")
                            </button>
                        </div>
                    </div>
                }
            </div>
            <div class="border border-border rounded-lg bg-card mt-6">
                <PaginationControl PageNumber="@_pageNumber" TotalPages="@_totalPages" PageChanged="OnPageChanged" />
            </div>
        }
    }
}

@if (_showDeleteScheduleConfirm)
{
    <div class="fixed inset-0 bg-background/80 backdrop-blur-sm flex items-center justify-center z-50">
        <div class="bg-card border border-border rounded-lg p-6 max-w-sm w-full shadow-lg">
            <h3 class="text-lg font-bold text-foreground mb-2">Delete Timetable?</h3>
