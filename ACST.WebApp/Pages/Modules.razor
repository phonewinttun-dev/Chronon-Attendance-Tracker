    private async Task LoadData()
    {
        _isLoading = true;
        try
        {
            var semFilter = _filterSemesterId.HasValue ? $"&semesterId={_filterSemesterId.Value}" : "";
            if (!string.IsNullOrWhiteSpace(_searchTerm))
            {
                var searchResult = await Http.GetFromJsonAsync<PagedResult<SearchModuleDto>>($"api/search/modules?name={Uri.EscapeDataString(_searchTerm)}&pageNumber={_pageNumber}&pageSize={_pageSize}{semFilter}");
                if (searchResult != null && searchResult.IsSuccess)
                {
                    _modules = searchResult.Data.Select(m => new ModuleDto
                    {
                        Id = m.Id,
                        Name = m.Name,
                        ModuleCode = m.ModuleCode,
                        TeacherName = m.TeacherName,
                        SemesterId = m.SemesterId,
                        SemesterName = m.SemesterName,
                        Schedules = new(),
                        TotalValidSessions = 0,
                        PresentSessions = 0,
                        AttendanceRate = 0
                    }).ToList();
                    _pageNumber = searchResult.Pagination.PageNumber;
                    _pageSize = searchResult.Pagination.PageSize;
                    _totalPages = searchResult.Pagination.TotalPages;
                    _totalCount = searchResult.Pagination.TotalCount;
                    _hasPrevious = searchResult.Pagination.HasPreviousPage;
                    _hasNext = searchResult.Pagination.HasNextPage;
                }
            }
            else
            {
                var modResult = await Http.GetFromJsonAsync<PagedResult<ModuleDto>>($"api/modules?pageNumber={_pageNumber}&pageSize={_pageSize}{semFilter}");
                if (modResult != null && modResult.IsSuccess)
                {
                    _modules = modResult.Data;
                    _pageNumber = modResult.Pagination.PageNumber;
                    _pageSize = modResult.Pagination.PageSize;
                    _totalPages = modResult.Pagination.TotalPages;
                    _totalCount = modResult.Pagination.TotalCount;
                    _hasPrevious = modResult.Pagination.HasPreviousPage;
                    _hasNext = modResult.Pagination.HasNextPage;
                }
            }

            if (_selectedModuleId > 0 && _modules != null)
            {
                _selectedModule = _modules.FirstOrDefault(m => m.Id == _selectedModuleId);
            }
            
            var semResult = await Http.GetFromJsonAsync<PagedResult<SemesterDto>>("api/semesters");
            if (semResult != null && semResult.IsSuccess)
            {
                _semesters = semResult.Data;
            }
        }
        catch (Exception ex)
        {
            _message = ex.GetFriendlyErrorMessage("Error loading data");
            _isError = true;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task CreateModule()
    {
        _isSubmitting = true;
        _message = string.Empty;

        _newModule.Schedules = _newModuleSchedules;

        try
        {
            var response = await Http.PostAsJsonAsync("api/modules", _newModule);
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<ApiResult<ModuleDto>>();
                if (result != null && result.IsSuccess)
                {
                    _message = "Module created successfully.";
                    _isError = false;
                    _showCreateForm = false;
                    _newModule = new CreateModuleRequest();
                    _newModuleSchedules.Clear();
                    _pageNumber = 1;
                    await LoadData();
                }
                else
                {
                    _message = result?.Message ?? "Unknown error creating module.";
                    _isError = true;
                }
            }
            else
            {
                _message = await response.GetFriendlyErrorMessageAsync("Error creating module");
                _isError = true;
            }
        }
        catch (Exception ex)
        {
            _message = ex.GetFriendlyErrorMessage("Error creating module");
            _isError = true;
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    private async Task UpdateModule()
    {
        if (string.IsNullOrWhiteSpace(_editModule.Name))
        {
            _message = "Module name is required.";
            _isError = true;
            return;
        }

        if (string.IsNullOrWhiteSpace(_editModule.ModuleCode))
        {
            _message = "Module code is required.";
            _isError = true;
            return;
        }

        _isSubmittingEdit = true;
        _message = string.Empty;

        _editModule.Schedules = _editModuleSchedules;

        try
        {
            var response = await Http.PutAsJsonAsync($"api/modules/{_editingModuleId}", _editModule);
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<ApiResult<ModuleDto>>();
                if (result != null && result.IsSuccess)
                {
                    _message = "Module updated successfully.";
                    _isError = false;
                    _showEditForm = false;
                    _editingModuleId = 0;
                    _editModuleSchedules.Clear();
                    await LoadData();
                }
                else
                {
                    _message = result?.Message ?? "Unknown error updating module.";
                    _isError = true;
                }
            }
            else
            {
                _message = await response.GetFriendlyErrorMessageAsync("Error updating module");
                _isError = true;
            }
        }
        catch (Exception ex)
        {
            _message = ex.GetFriendlyErrorMessage("Error updating module");
            _isError = true;
        }
        finally
        {
            _isSubmittingEdit = false;
        }
    }
    
    private async Task CreateSchedule()
    {
        if (_selectedSemesterId == 0)
        {
            _message = "Please select a semester.";
            _isError = true;
            return;
        }

        if (!_assignSchedules.Any())
        {
            _message = "Please add at least one schedule.";
            _isError = true;
            return;
        }
        
        _isSubmittingSchedule = true;
        _message = string.Empty;

        try
        {
            bool allSuccess = true;
            string errorDetails = "";

            foreach (var sch in _assignSchedules)
            {
                if (sch.StartTime >= sch.EndTime)
                {
                    _message = "Start time must be before end time for all schedules.";
                    _isError = true;
                    _isSubmittingSchedule = false;
                    return;
                }
            }

            foreach (var sch in _assignSchedules)
            {
                var response = await Http.PostAsJsonAsync($"api/modules/{_selectedModuleId}/recurring-schedules/{_selectedSemesterId}", sch);
                if (!response.IsSuccessStatusCode)
                {
                    allSuccess = false;
                    errorDetails = await response.GetFriendlyErrorMessageAsync("Error adding schedule");
                    break;
                }
                else
                {
                    var result = await response.Content.ReadFromJsonAsync<ApiResult<RecurringScheduleDto>>();
                    if (result == null || !result.IsSuccess)
                    {
                        allSuccess = false;
                        errorDetails = result?.Message ?? "Unknown error adding schedule.";
                        break;
                    }
                }
            }

            if (allSuccess)
            {
                _message = "Schedules added successfully.";
                _isError = false;
                _selectedModuleId = 0;
                _selectedModuleName = string.Empty;
                _selectedModule = null;
                _selectedSemesterId = 0;
                _assignSchedules = new();
                await LoadData();
            }
            else
            {
                _message = errorDetails;
                _isError = true;
            }
        }
        catch (Exception ex)
        {
            _message = ex.GetFriendlyErrorMessage("Error adding schedules");
            _isError = true;
        }
        finally
        {
            _isSubmittingSchedule = false;
        }
    }

    private async Task DeleteModule(long id)
    {
        if (_deletingModuleIds.Contains(id)) return;
        _deletingModuleIds.Add(id);
        _message = string.Empty;
        try
        {
            var response = await Http.DeleteAsync($"api/modules/{id}");
            if (response.IsSuccessStatusCode)
            {
                _showModuleDeleteSuccess = true;
                if (_modules != null && _modules.Count == 1 && _pageNumber > 1)
                {
                    _pageNumber--;
                }
                await LoadData();
            }
            else
            {
                _message = await response.GetFriendlyErrorMessageAsync("Error deleting module");
                _isError = true;
            }
        }
        catch (Exception ex)
        {
            _message = ex.GetFriendlyErrorMessage("Error deleting module");
            _isError = true;
        }
        finally
        {
            _deletingModuleIds.Remove(id);
        }
    }

    private string GetHealthColorClass(double rate)
    {
        if (rate >= 75) return "text-emerald-500";
        if (rate >= 60) return "text-amber-500";
        return "text-destructive";
    }

    private string GetHealthBgClass(double rate)
    {
        if (rate >= 75) return "bg-emerald-500";
        if (rate >= 60) return "bg-amber-500";
        return "bg-destructive";
    }

    private string GetBadgeBorderAndBg(double rate)
    {
        if (rate >= 75) return "border-emerald-500/20 text-emerald-500 bg-emerald-500/10";
        if (rate >= 60) return "border-amber-500/20 text-amber-500 bg-amber-500/10";
        return "border-destructive/20 text-destructive bg-destructive/10";
    }

