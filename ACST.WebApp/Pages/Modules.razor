@if (_showModuleDeleteSuccess)
{
    <div class="fixed inset-0 bg-background/80 backdrop-blur-sm flex items-center justify-center z-50">
        <div class="bg-card border border-border rounded-lg p-6 max-w-sm w-full shadow-lg text-center animate-in fade-in zoom-in duration-200">
            <div class="mx-auto flex items-center justify-center h-12 w-12 rounded-full bg-emerald-500/10 text-emerald-500 mb-4">
                <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
            </div>
            <h3 class="text-base font-bold text-foreground mb-2">Module Deleted</h3>
            <p class="text-xs text-muted-foreground mb-5 font-sans">Module deleted successfully.</p>
            <button class="w-full py-2 bg-primary text-primary-foreground hover:bg-primary/95 rounded-md text-xs font-semibold transition-colors focus:outline-none"
                    @onclick="CloseModuleDeleteSuccess">
                Close
            </button>
        </div>
    </div>
}

@code {
    private static string _viewMode = "table";
    private List<ModuleDto>? _modules;
    private List<SemesterDto>? _semesters;
    private HashSet<long> _deletingModuleIds = new();
    
    private bool _isLoading = true;
    private bool _showCreateForm = false;
    private bool _isSubmitting = false;
    private bool _isSubmittingSchedule = false;
    private bool _showCreateModuleConfirm = false;
    private bool _showGenerateSessionsConfirm = false;
    private string _message = string.Empty;
    private bool _isError = false;
    private string _searchTerm = string.Empty;

    private bool _showDeleteModuleConfirm = false;
    private long _moduleIdToDelete = 0;

    private bool _isDeletingSchedule = false;
    private bool _showScheduleDeleteSuccess = false;
    private bool _showScheduleDeleteFailure = false;
    private bool _showModuleDeleteSuccess = false;
    private long? _filterSemesterId = null;
    private string _selectedFilterSemesterIdStr
    {
        get => _filterSemesterId?.ToString() ?? "";
        set
        {
            if (long.TryParse(value, out var id))
                _filterSemesterId = id;
            else
                _filterSemesterId = null;
        }
    }

    private int _pageNumber = 1;
    private int _pageSize = 10;
    private int _totalPages = 1;
    private int _totalCount = 0;
    private bool _hasPrevious = false;
    private bool _hasNext = false;

    private CreateModuleRequest _newModule = new();
    private List<CreateRecurringScheduleRequest> _newModuleSchedules = new();

    private string _newModuleSemesterIdStr
    {
        get => _newModule.SemesterId?.ToString() ?? "";
        set
        {
            if (long.TryParse(value, out var id))
            {
                _newModule.SemesterId = id;
            }
            else
            {
                _newModule.SemesterId = null;
                _newModuleSchedules.Clear();
            }
        }
    }

    private UpdateModuleRequest _editModule = new();
    private List<UpdateRecurringScheduleRequest> _editModuleSchedules = new();
    private long _editingModuleId = 0;
    private bool _showEditForm = false;
    private bool _isSubmittingEdit = false;

    private string _editModuleSemesterIdStr
    {
        get => _editModule.SemesterId?.ToString() ?? "";
        set
        {
            if (long.TryParse(value, out var id))
            {
                _editModule.SemesterId = id;
            }
            else
            {
                _editModule.SemesterId = null;
                _editModuleSchedules.Clear();
            }
        }
    }
    
    private long _selectedModuleId = 0;
    private string _selectedModuleName = string.Empty;
    private long _selectedSemesterId
    {
        get => _selectedSemesterIdVal;
        set
        {
            _selectedSemesterIdVal = value;
            _selectedSemester = _semesters?.FirstOrDefault(s => s.Id == value);
            if (value == 0)
            {
                _assignSchedules.Clear();
            }
            else if (!_assignSchedules.Any())
            {
                _assignSchedules.Add(new CreateRecurringScheduleRequest 
                { 
                    StartTime = new TimeOnly(9, 0), 
                    EndTime = new TimeOnly(11, 0), 
                    DayOfWeek = 1 
                });
            }
        }
    }
    private long _selectedSemesterIdVal = 0;
    private SemesterDto? _selectedSemester = null;
    private ModuleDto? _selectedModule = null;
    private List<CreateRecurringScheduleRequest> _assignSchedules = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private void ToggleCreateForm()
    {
        _showCreateForm = !_showCreateForm;
        _message = string.Empty;
        if (_showCreateForm)
        {
            _selectedModuleId = 0;
            _selectedModuleName = string.Empty;
            _showEditForm = false;
            _editingModuleId = 0;
            _newModuleSchedules.Clear();
        }
    }
    
    private void OpenScheduleForm(ModuleDto mod)
    {
        _selectedModuleId = mod.Id;
        _selectedModuleName = mod.Name;
        _selectedModule = mod;
        _selectedSemesterId = 0;
        _showCreateForm = false;
        _showEditForm = false;
        _editingModuleId = 0;
        _message = string.Empty;
        _assignSchedules = new();
    }
    
    private void CancelScheduleForm()
    {
        _selectedModuleId = 0;
        _selectedModuleName = string.Empty;
        _selectedModule = null;
        _selectedSemesterId = 0;
        _assignSchedules = new();
    }

    private void OpenEditForm(ModuleDto mod)
    {
        _editingModuleId = mod.Id;
        _editModule = new UpdateModuleRequest
        {
            Name = mod.Name,
            ModuleCode = mod.ModuleCode,
            TeacherName = mod.TeacherName,
            SemesterId = mod.SemesterId
        };
