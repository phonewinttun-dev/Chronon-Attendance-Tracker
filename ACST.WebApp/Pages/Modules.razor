        <div class="bg-card border border-border rounded-lg p-6 max-w-sm w-full shadow-lg flex flex-col items-center justify-center text-center">
            <div class="animate-spin rounded-full h-8 w-8 border-b-2 border-primary mb-4"></div>
            <h3 class="text-sm font-bold text-foreground">Deleting Timetable...</h3>
