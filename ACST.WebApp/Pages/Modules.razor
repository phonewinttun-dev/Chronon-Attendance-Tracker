@page "/modules"
@using ACST.WebApp.Models
@inject HttpClient Http

<PageTitle>Modules</PageTitle>

<div class="flex justify-between items-center mb-8">
    <h1 class="text-3xl font-bold">Modules</h1>
    <button class="bg-primary hover:bg-primary-fixed-dim text-on-primary font-medium px-4 py-2 rounded-md transition-colors" @onclick="ToggleCreateForm">
        @(_showCreateForm ? "Cancel" : "New Module")
    </button>
</div>

@if (!string.IsNullOrEmpty(_message))
{
    <div class="bg-surface-container border @(_isError ? "border-error text-error" : "border-primary text-primary") p-4 rounded-md mb-6">
        @_message
    </div>
}

@if (_showCreateForm)
{
    <div class="bg-surface-container border border-outline-variant p-6 rounded-md shadow-md mb-8">
        <h2 class="text-xl font-bold mb-4 text-on-surface">Create New Module</h2>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
            <div>
                <label class="block text-on-surface-variant mb-2">Module Name</label>
                <input type="text" class="w-full p-3 bg-surface border border-outline-variant rounded-md text-on-surface focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary" @bind="_newModule.Name" placeholder="e.g. CS101" />
            </div>
            <div>
                <label class="block text-on-surface-variant mb-2">Teacher Name</label>
                <input type="text" class="w-full p-3 bg-surface border border-outline-variant rounded-md text-on-surface focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary" @bind="_newModule.TeacherName" placeholder="e.g. John Doe" />
            </div>
        </div>

        <button class="bg-primary hover:bg-primary-fixed-dim text-on-primary font-medium px-6 py-3 rounded-md transition-colors disabled:opacity-50" @onclick="CreateModule" disabled="@_isSubmitting">
            @(_isSubmitting ? "Creating..." : "Create Module")
        </button>
    </div>
}

<!-- Assign Schedule Form -->
@if (_selectedModuleId > 0)
{
    <div class="bg-surface-variant border border-primary p-6 rounded-md shadow-md mb-8">
        <div class="flex justify-between items-center mb-4">
            <h2 class="text-xl font-bold text-on-surface">Add Schedule to Module #@_selectedModuleId</h2>
            <button class="text-on-surface-variant hover:text-on-surface" @onclick="CancelScheduleForm">Cancel</button>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-4 gap-4 mb-6">
            <div>
                <label class="block text-on-surface-variant mb-2">Semester</label>
                <select class="w-full p-3 bg-surface border border-outline-variant rounded-md text-on-surface focus:outline-none focus:border-primary" @bind="_selectedSemesterId">
                    <option value="0">Select Semester...</option>
                    @if (_semesters != null)
                    {
                        @foreach(var sem in _semesters)
                        {
                            <option value="@sem.Id">@sem.Name</option>
                        }
                    }
                </select>
            </div>
            <div>
                <label class="block text-on-surface-variant mb-2">Day of Week</label>
                <select class="w-full p-3 bg-surface border border-outline-variant rounded-md text-on-surface focus:outline-none focus:border-primary" @bind="_newSchedule.DayOfWeek">
                    <option value="1">Monday</option>
                    <option value="2">Tuesday</option>
                    <option value="3">Wednesday</option>
                    <option value="4">Thursday</option>
                    <option value="5">Friday</option>
                    <option value="6">Saturday</option>
                    <option value="0">Sunday</option>
                </select>
            </div>
            <div>
                <label class="block text-on-surface-variant mb-2">Start Time</label>
                <input type="time" class="w-full p-3 bg-surface border border-outline-variant rounded-md text-on-surface focus:outline-none focus:border-primary" @bind="_newSchedule.StartTime" />
            </div>
            <div>
                <label class="block text-on-surface-variant mb-2">End Time</label>
                <input type="time" class="w-full p-3 bg-surface border border-outline-variant rounded-md text-on-surface focus:outline-none focus:border-primary" @bind="_newSchedule.EndTime" />
            </div>
        </div>

        <button class="bg-primary hover:bg-primary-fixed-dim text-on-primary font-medium px-6 py-3 rounded-md transition-colors disabled:opacity-50" @onclick="CreateSchedule" disabled="@_isSubmittingSchedule">
            @(_isSubmittingSchedule ? "Adding..." : "Add Schedule")
        </button>
    </div>
}

<div class="bg-surface-container border border-outline-variant rounded-md shadow-md overflow-hidden">
    @if (_isLoading)
    {
        <div class="p-6 text-on-surface-variant">Loading modules...</div>
    }
    else if (_modules == null || !_modules.Any())
    {
        <div class="p-6 text-on-surface-variant">No modules found. Create one to get started.</div>
    }
    else
    {
        <table class="w-full text-left border-collapse">
            <thead>
                <tr class="border-b border-outline-variant bg-surface-variant">
                    <th class="px-6 py-4 text-xs font-semibold text-on-surface-variant uppercase tracking-wider">Module</th>
                    <th class="px-6 py-4 text-xs font-semibold text-on-surface-variant uppercase tracking-wider">Teacher</th>
                    <th class="px-6 py-4 text-xs font-semibold text-on-surface-variant uppercase tracking-wider">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-outline-variant">
                @foreach (var mod in _modules)
                {
                    <tr class="hover:bg-surface-variant/50 transition-colors">
                        <td class="px-6 py-4 font-semibold text-on-surface">@mod.Name</td>
                        <td class="px-6 py-4 text-on-surface-variant">@mod.TeacherName</td>
                        <td class="px-6 py-4">
                            <button class="text-primary border border-primary px-3 py-1 rounded hover:bg-primary hover:text-on-primary transition-colors text-sm mr-2" @onclick="() => OpenScheduleForm(mod.Id)">Add Schedule</button>
                            <button class="text-error border border-error px-3 py-1 rounded hover:bg-error hover:text-on-error transition-colors text-sm" @onclick="() => DeleteModule(mod.Id)">Delete</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

@code {
    private List<ModuleDto>? _modules;
    private List<SemesterDto>? _semesters;
    
    private bool _isLoading = true;
    private bool _showCreateForm = false;
    private bool _isSubmitting = false;
    private bool _isSubmittingSchedule = false;
    private string _message = string.Empty;
    private bool _isError = false;

    private CreateModuleRequest _newModule = new();
    
    private long _selectedModuleId = 0;
    private long _selectedSemesterId = 0;
    private CreateRecurringScheduleRequest _newSchedule = new()
    {
        StartTime = new TimeOnly(9, 0),
        EndTime = new TimeOnly(11, 0),
        DayOfWeek = 1
    };

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private void ToggleCreateForm()
    {
        _showCreateForm = !_showCreateForm;
        _message = string.Empty;
        if (_showCreateForm) _selectedModuleId = 0;
    }
    
    private void OpenScheduleForm(long moduleId)
    {
        _selectedModuleId = moduleId;
        _showCreateForm = false;
        _message = string.Empty;
    }
    
    private void CancelScheduleForm()
    {
        _selectedModuleId = 0;
    }

    private async Task LoadData()
    {
        _isLoading = true;
        try
        {
            var modResult = await Http.GetFromJsonAsync<ApiResult<List<ModuleDto>>>("api/modules");
            if (modResult != null && modResult.IsSuccess)
            {
                _modules = modResult.Data;
            }
            
            var semResult = await Http.GetFromJsonAsync<ApiResult<List<SemesterDto>>>("api/semesters");
            if (semResult != null && semResult.IsSuccess)
            {
                _semesters = semResult.Data;
            }
        }
        catch (Exception ex)
        {
            _message = "Error loading data: " + ex.Message;
            _isError = true;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task CreateModule()
    {
        _isSubmitting = true;
        _message = string.Empty;

        try
        {
            var response = await Http.PostAsJsonAsync("api/modules", _newModule);
            var result = await response.Content.ReadFromJsonAsync<ApiResult<ModuleDto>>();

            if (result != null && result.IsSuccess)
            {
                _message = "Module created successfully.";
                _isError = false;
                _showCreateForm = false;
                _newModule = new CreateModuleRequest();
                await LoadData();
            }
            else
            {
                _message = result?.Message ?? "Unknown error creating module.";
                _isError = true;
            }
        }
        catch (Exception ex)
        {
            _message = "Error: " + ex.Message;
            _isError = true;
        }
        finally
        {
            _isSubmitting = false;
        }
    }
    
    private async Task CreateSchedule()
    {
        if (_selectedSemesterId == 0)
        {
            _message = "Please select a semester.";
            _isError = true;
            return;
        }
        
        _isSubmittingSchedule = true;
        _message = string.Empty;

        try
        {
            var response = await Http.PostAsJsonAsync($"api/modules/{_selectedModuleId}/recurring-schedules/{_selectedSemesterId}", _newSchedule);
            var result = await response.Content.ReadFromJsonAsync<ApiResult<RecurringScheduleDto>>();

            if (result != null && result.IsSuccess)
            {
                _message = "Schedule added successfully.";
                _isError = false;
                _selectedModuleId = 0;
                // reset
                _newSchedule = new CreateRecurringScheduleRequest
                {
                    StartTime = new TimeOnly(9, 0),
                    EndTime = new TimeOnly(11, 0),
                    DayOfWeek = 1
                };
            }
            else
            {
                _message = result?.Message ?? "Unknown error adding schedule.";
                _isError = true;
            }
        }
        catch (Exception ex)
        {
            _message = "Error: " + ex.Message;
            _isError = true;
        }
        finally
        {
            _isSubmittingSchedule = false;
        }
    }

    private async Task DeleteModule(long id)
    {
        try
        {
            var response = await Http.DeleteAsync($"api/modules/{id}");
            if (response.IsSuccessStatusCode)
            {
                await LoadData();
            }
        }
        catch
        {
            // Handle error
        }
    }
}
