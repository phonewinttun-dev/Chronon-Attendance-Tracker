@inject HttpClient Http
@inject NavigationManager Navigation
@implements IDisposable

<div class="relative inline-block text-left">
    <!-- Bell Button -->
    <button @onclick="ToggleDropdown" 
            class="relative p-2 rounded-lg bg-card hover:bg-accent text-muted-foreground hover:text-accent-foreground transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-primary/20 border border-border/50 shadow-sm"
            title="Notifications" 
            aria-label="Notifications">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5">
            <path d="M6 8a6 6 0 0 1 12 0c0 7 3 9 3 9H3s3-2 3-9"/>
            <path d="M10.3 21a1.94 1.94 0 0 0 3.4 0"/>
        </svg>

        @if (_unreadCount > 0)
        {
            <span class="absolute -top-1 -right-1 flex h-5 w-5 items-center justify-center rounded-full bg-destructive text-[10px] font-bold text-destructive-foreground shadow-sm animate-pulse">
                @(_unreadCount > 99 ? "99+" : _unreadCount.ToString())
            </span>
        }
    </button>

    <!-- Dropdown Menu -->
    @if (_isOpen)
    {
        <!-- Backdrop to close dropdown -->
        <div class="fixed inset-0 z-40" @onclick="CloseDropdown"></div>

        <div class="absolute right-0 mt-2 w-80 md:w-96 rounded-xl bg-card border border-border shadow-2xl z-50 overflow-hidden flex flex-col max-h-[85vh] animate-in fade-in zoom-in-95 duration-150" style="background-color: hsl(var(--card)); opacity: 1;">
            <!-- Header -->
            <div class="p-4 border-b border-border flex items-center justify-between bg-card">
                <div class="flex items-center gap-2">
                    <h3 class="font-semibold text-sm tracking-tight text-foreground">Notifications</h3>
                    @if (_unreadCount > 0)
                    {
                        <span class="px-2 py-0.5 text-xs font-medium bg-primary/10 text-primary rounded-full border border-primary/20">
                            @_unreadCount unread
                        </span>
                    }
                </div>
                <div class="flex items-center gap-2">
                    @if (_unreadCount > 0)
                    {
                        <button @onclick="MarkAllAsRead" class="text-xs text-primary hover:underline font-medium focus:outline-none cursor-pointer">
                            Mark all read
                        </button>
                    }
                </div>
            </div>

            <!-- Tabs -->
            <div class="flex border-b border-border bg-card px-4 text-xs font-medium">
                <button @onclick="() => SetFilter(false)" 
                        class="py-2.5 px-3 border-b-2 transition-colors cursor-pointer @(!_showUnreadOnly ? "border-primary text-primary font-semibold" : "border-transparent text-muted-foreground hover:text-foreground")">
                    All
                </button>
                <button @onclick="() => SetFilter(true)" 
                        class="py-2.5 px-3 border-b-2 transition-colors cursor-pointer @(_showUnreadOnly ? "border-primary text-primary font-semibold" : "border-transparent text-muted-foreground hover:text-foreground")">
                    Unread (@_unreadCount)
                </button>
            </div>

            <!-- List Content -->
            <div class="overflow-y-auto divide-y divide-border/40 flex-1 bg-card">
                @if (_isLoading)
                {
                    <div class="p-8 text-center text-xs text-muted-foreground flex items-center justify-center gap-2 bg-card">
                        <svg class="animate-spin h-4 w-4 text-primary" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                        </svg>
                        Loading notifications...
                    </div>
                }
                else if (_notifications == null || !_notifications.Any())
                {
                    <div class="p-8 text-center text-xs text-muted-foreground flex flex-col items-center gap-2 bg-card">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="w-8 h-8 opacity-40">
                            <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/>
                            <path d="M13.73 21a2 2 0 0 1-3.46 0"/>
                        </svg>
                        <span>No notifications to show.</span>
                    </div>
                }
                else
                {
                    @foreach (var notification in _notifications)
                    {
                        <div class="p-4 transition-colors flex gap-3 items-start relative group @(!notification.IsRead ? "bg-primary/10 hover:bg-primary/15 font-medium" : "bg-card hover:bg-accent/50")">
                            <!-- Type Icon -->
                            <div class="mt-0.5 shrink-0 p-2 rounded-lg @GetTypeIconStyle(notification.NotificationType)">
                                @GetTypeIcon(notification.NotificationType)
                            </div>

                            <!-- Body -->
                            <div class="flex-1 min-w-0">
                                <div class="flex items-center justify-between gap-2">
                                    <h4 class="text-xs font-semibold tracking-tight text-foreground truncate">@notification.Title</h4>
                                    <span class="text-[10px] text-muted-foreground shrink-0">@GetTimeAgo(notification.CreatedAt)</span>
                                </div>
                                <p class="text-xs text-muted-foreground mt-1 line-clamp-2 leading-relaxed">@notification.Message</p>
                                
                                <div class="mt-2.5 flex items-center justify-between gap-2">
                                    @if (notification.SessionId.HasValue)
                                    {
                                        <button @onclick="() => NavigateToSession(notification.SessionId.Value)" 
                                                class="text-[11px] font-semibold text-primary hover:underline flex items-center gap-1 cursor-pointer">
                                            View Session
                                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-3 h-3"><path d="m9 18 6-6-6-6"/></svg>
                                        </button>
                                    }
                                    else
                                    {
                                        <div></div>
                                    }

                                    @if (!notification.IsRead)
                                    {
                                        <button @onclick="() => MarkAsRead(notification.NotificationId)" 
                                                class="text-[10px] text-muted-foreground hover:text-foreground font-medium px-2 py-0.5 rounded bg-muted/50 hover:bg-muted transition-colors cursor-pointer">
                                            Mark as read
                                        </button>
                                    }
                                </div>
                            </div>

                            <!-- Unread Indicator Dot -->
                            @if (!notification.IsRead)
                            {
                                <span class="absolute top-4 right-2 w-2 h-2 rounded-full bg-primary"></span>
                            }
                        </div>
                    }
                }
            </div>
        </div>
    }
</div>

@code {
    private bool _isOpen = false;
    private bool _isLoading = false;
    private bool _showUnreadOnly = false;
    private int _unreadCount = 0;
    private List<NotificationDto>? _notifications;
    private System.Threading.Timer? _refreshTimer;

    protected override async Task OnInitializedAsync()
    {
        await FetchUnreadCount();
        _refreshTimer = new System.Threading.Timer(async _ =>
        {
            await InvokeAsync(async () =>
            {
                await FetchUnreadCount();
                StateHasChanged();
            });
        }, null, TimeSpan.FromSeconds(30), TimeSpan.FromSeconds(30));
    }

    private async Task FetchUnreadCount()
    {
        try
        {
            var res = await Http.GetFromJsonAsync<ApiResult<NotificationCountDto>>("api/notifications/unread-count?userId=1");
            if (res != null && res.IsSuccess && res.Data != null)
            {
                _unreadCount = res.Data.UnreadCount;
            }
        }
        catch { }
    }

    private async Task FetchNotifications()
    {
        _isLoading = true;
        try
        {
            var url = $"api/notifications?userId=1&unreadOnly={_showUnreadOnly}";
            var res = await Http.GetFromJsonAsync<ApiResult<List<NotificationDto>>>(url);
            if (res != null && res.IsSuccess && res.Data != null)
            {
                _notifications = res.Data;
            }
        }
        catch
        {
            _notifications = new List<NotificationDto>();
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task ToggleDropdown()
    {
        _isOpen = !_isOpen;
        if (_isOpen)
        {
            await FetchNotifications();
        }
    }

    private void CloseDropdown()
    {
        _isOpen = false;
    }

    private async Task SetFilter(bool unreadOnly)
    {
        _showUnreadOnly = unreadOnly;
        await FetchNotifications();
    }

    private async Task MarkAsRead(long notificationId)
    {
        try
        {
            var response = await Http.PutAsync($"api/notifications/{notificationId}/read?userId=1", null);
            if (response.IsSuccessStatusCode)
            {
                var target = _notifications?.FirstOrDefault(n => n.NotificationId == notificationId);
                if (target != null)
                {
                    target.IsRead = true;
                }
                await FetchUnreadCount();
            }
        }
        catch { }
    }

    private async Task MarkAllAsRead()
    {
        try
        {
            var response = await Http.PutAsync("api/notifications/read-all?userId=1", null);
            if (response.IsSuccessStatusCode)
            {
                if (_notifications != null)
                {
                    foreach (var n in _notifications) n.IsRead = true;
                }
                await FetchUnreadCount();
            }
        }
        catch { }
    }

    private void NavigateToSession(long sessionId)
    {
        _isOpen = false;
        Navigation.NavigateTo($"attendance?sessionId={sessionId}");
    }

    private string GetTypeIconStyle(string type) => type switch
    {
        "UpcomingClass" => "bg-blue-500/10 text-blue-500",
        "AttendanceReminder30Min" => "bg-amber-500/10 text-amber-500",
        "EveningAttendanceReminder" => "bg-purple-500/10 text-purple-500",
        _ => "bg-muted text-muted-foreground"
    };

    private RenderFragment GetTypeIcon(string type) => builder =>
    {
        switch (type)
        {
            case "UpcomingClass":
                builder.OpenElement(0, "svg");
                builder.AddAttribute(1, "xmlns", "http://www.w3.org/2000/svg");
                builder.AddAttribute(2, "viewBox", "0 0 24 24");
                builder.AddAttribute(3, "fill", "none");
                builder.AddAttribute(4, "stroke", "currentColor");
                builder.AddAttribute(5, "stroke-width", "2");
                builder.AddAttribute(6, "class", "w-4 h-4");
                builder.AddMarkupContent(7, "<rect width='18' height='18' x='3' y='4' rx='2'/><path d='M3 10h18'/><path d='M8 2v4'/><path d='M16 2v4'/>");
                builder.CloseElement();
                break;
            case "AttendanceReminder30Min":
                builder.OpenElement(0, "svg");
                builder.AddAttribute(1, "xmlns", "http://www.w3.org/2000/svg");
                builder.AddAttribute(2, "viewBox", "0 0 24 24");
                builder.AddAttribute(3, "fill", "none");
                builder.AddAttribute(4, "stroke", "currentColor");
                builder.AddAttribute(5, "stroke-width", "2");
                builder.AddAttribute(6, "class", "w-4 h-4");
                builder.AddMarkupContent(7, "<circle cx='12' cy='12' r='10'/><polyline points='12 6 12 12 16 14'/>");
                builder.CloseElement();
                break;
            case "EveningAttendanceReminder":
            default:
                builder.OpenElement(0, "svg");
                builder.AddAttribute(1, "xmlns", "http://www.w3.org/2000/svg");
                builder.AddAttribute(2, "viewBox", "0 0 24 24");
                builder.AddAttribute(3, "fill", "none");
                builder.AddAttribute(4, "stroke", "currentColor");
                builder.AddAttribute(5, "stroke-width", "2");
                builder.AddAttribute(6, "class", "w-4 h-4");
                builder.AddMarkupContent(7, "<path d='M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z'/>");
                builder.CloseElement();
                break;
        }
    };

    private string GetTimeAgo(DateTime dateTime)
    {
        var span = DateTime.UtcNow - dateTime;
        if (span.TotalMinutes < 1) return "Just now";
        if (span.TotalMinutes < 60) return $"{(int)span.TotalMinutes}m ago";
        if (span.TotalHours < 24) return $"{(int)span.TotalHours}h ago";
        if (span.TotalDays < 7) return $"{(int)span.TotalDays}d ago";
        return dateTime.ToLocalTime().ToString("MMM dd");
    }

    public void Dispose()
    {
        _refreshTimer?.Dispose();
    }
}
