            </NavLink>
            <NavLink class="@GetNavLinkClass()" href="holidays" ActiveClass="bg-accent text-accent-foreground font-semibold shadow-sm" title="@(_isCollapsed ? "Holidays" : "")" @onclick="CloseMobileMenu">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" class="w-6 h-6 shrink-0"><path fill-rule="evenodd" clip-rule="evenodd" d="M14 13.25C13.0335 13.25 12.25 14.0335 12.25 15V18C12.25 18.9665 13.0335 19.75 14 19.75H17C17.9665 19.75 18.75 18.9665 18.75 18V15C18.75 14.0335 17.9665 13.25 17 13.25H14ZM13.75 15C13.75 14.8619 13.8619 14.75 14 14.75H17C17.1381 14.75 17.25 14.8619 17.25 15V18C17.25 18.1381 17.1381 18.25 17 18.25H14C13.8619 18.25 13.75 18.1381 13.75 18V15Z" fill="currentColor"></path><path fill-rule="evenodd" clip-rule="evenodd" d="M8 0.25C8.41421 0.25 8.75 0.585786 8 1V2.25H15.25V1C15.25 0.585786 15.5858 0.25 16 0.25C16.4142 0.25 16.75 0.585786 16 1V2.25007C17.5561 2.25064 18.2154 2.25569 18.7599 2.30018C19.3899 2.35165 19.9318 2.45963 20.4295 2.71322C21.2291 3.12068 21.8793 3.77085 22.2868 4.57054C22.5404 5.06824 22.6483 5.61012 22.6998 6.24013C22.75 6.85438 22.75 7.6149 22.75 8.5673V17.4326C22.75 18.385 22.75 19.1456 22.6998 19.7599C22.6483 20.3899 22.5404 20.9318 22.2868 21.4295C21.8793 22.2291 21.2291 22.8793 20.4295 23.2868C19.9318 23.5404 19.3899 23.6483 18.7599 23.6998C18.1456 23.75 17.3851 23.75 16.4327 23.75H7.56737C6.61496 23.75 5.85438 23.75 5.24013 23.6998C4.61012 23.6483 4.06824 23.5404 3.57054 23.2868C2.77085 22.8793 2.12068 22.2291 1.71322 21.4295C1.45963 20.9318 1.35165 20.3899 1.30018 19.7599C1.24999 19.1456 1.24999 18.3851 1.25 17.4326V8.56739C1.24999 7.61495 1.24999 6.85439 1.30018 6.24013C1.35165 5.61012 1.45963 5.06824 1.71322 4.57054C2.12068 3.77085 2.77085 3.12068 3.57054 2.71322C4.06824 2.45963 4.61012 2.35165 5.24013 2.30018C5.78458 2.25569 6.44395 2.25064 7.25 2.25007V1C7.25 0.585786 7.58579 0.25 8 0.25ZM7.6 3.75C6.60753 3.75 5.90829 3.75058 5.36228 3.79519C4.82503 3.83909 4.50252 3.92184 4.25153 4.04973C3.73408 4.31338 3.31338 4.73408 3.04973 5.25153C2.92184 5.50252 2.83909 5.82503 2.79519 6.36228C2.76455 6.7374 2.75468 7.18484 2.7515 7.75H21.2485C21.2453 7.18484 21.2355 6.7374 21.2048 6.36228C21.