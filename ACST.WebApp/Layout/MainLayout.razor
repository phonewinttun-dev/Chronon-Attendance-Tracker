                <span class="@GetNavLinkTextClass()">
                    Holidays
                </span>
            </NavLink>
            <NavLink class="@GetNavLinkClass()" href="sessions" ActiveClass="bg-accent text-accent-foreground font-semibold shadow-sm" title="@(_isCollapsed ? "Sessions" : "")" @onclick="CloseMobileMenu">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" class="w-6 h-6 shrink-0"><path fill-rule="evenodd" clip-rule="evenodd" d="M7.94513 1.25H16.0549C17.4225 1.24998 18.5248 1.24996 19.3918 1.36652C20.2919 1.48754 21.0497 1.74643 21.6517 2.34835C22.2536 2.95027 22.5125 3.70814 22.6335 4.60825C22.75 5.47522 22.75 6.57754 22.75 7.94513V12.0549C22.75 13.4225 22.75 14.5248 22.6335 15.3918C22.5125 16.2919 22.2536 17.0497 21.6517 17.6516C21.1537 18.1496 20.5469 18.4146 19.8361 18.5593C19.1459 18.6998 18.3133 18.7352 17.3276 18.7457L17.322 18.7458L17.0976 18.7464C17.0008 19.0506 16.8435 19.34 16.6255 19.5958C16.4944 19.7496 16.4152 19.9408 16.3991 20.1423C16.303 21.3466 15.3466 22.303 14.1423 22.3991C13.9409 22.4152 13.7496 22.4944 13.5958 22.6255C12.6762 23.4091 11.3238 23.4091 10.4042 22.6255C10.2504 22.4944 10.0592 22.4152 9.85771 22.3991C8.65336 22.303 7.69701 21.3466 7.6009 20.1423C7.58483 19.9409 7.50561 19.7496 7.37454 19.5958C7.15682 19.3403 6.99959 19.0514 6.90285 18.7477C5.86252 18.7407 4.9917 18.7125 4.27635 18.5811C3.51836 18.4418 2.87328 18.1766 2.34835 17.6517C1.74643 17.0497 1.48754 16.2919 1.36652 15.3918C1.24996 14.5248 1.24998 13.4225 1.25 12.0549V7.94513C1.24998 6.57754 1.24996 5.47522 1.36652 4.60825C1.48754 3.70814 1.74643 2.95027 2.34835 2.34835C2.95027 1.74643 3.70814 1.48754 4.60825 1.36652C5.47522 1.24996 6.57754 1.24998 7.94513 1.25ZM6.90434 17.2476C7.0012 16.9456 7.15794 16.6584 7.37454 16.4042C7.50561 16.2504 7.58483 16.0592 7.6009 15.8577C7.69701 14.6534 8.65336 13.697 9.85771 13.6009C10.0592 13.5848 10.2504 13.5056 10.4042 13.3745C11.3238 12.5909 12.6762 12.5909 13.5958 13.3745C13.7496 13.5056 13.9409 13.5848 14.1423 13.6009C15.3466 13.697 16.303 14.6534 16.3991 15.8577C16.4152 16.0592 16.4944 16.2504 16.6255 16.4042C16.8418 16.658 16.9984 16.9448 17.0953 17.2464L17.3144 17.2457C18.2997 17.2352 19.0022 17.1983 19.5368 17.0895C20.0513 16.9847 20.359 16.8229 20.591 16.591C20.8678 16.3142 21.0482 15.9257 21.1469 