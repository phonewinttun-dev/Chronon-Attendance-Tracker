@inherits LayoutComponentBase

<div class="flex flex-col md:flex-row min-h-screen bg-background text-foreground">
    <!-- Mobile Header -->
    <header class="h-16 bg-card border-b border-border flex items-center justify-between px-6 md:hidden shrink-0">
        <div class="flex items-center gap-3">
            <button @onclick="ToggleMobileMenu" class="p-1.5 rounded-md hover:bg-accent text-muted-foreground hover:text-accent-foreground transition-colors focus:outline-none" aria-label="Toggle Menu">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6">
                    <line x1="4" x2="20" y1="12" y2="12"/>
                    <line x1="4" x2="20" y1="6" y2="6"/>
                    <line x1="4" x2="20" y1="18" y2="18"/>
                </svg>
            </button>
            <span class="font-bold text-lg tracking-tight font-sans">Chronon Tracker</span>
        </div>
        <NotificationBell />
    </header>

    <!-- Mobile Drawer Backdrop -->
    @if (_isMobileMenuOpen)
    {
        <div class="fixed inset-0 bg-black/60 backdrop-blur-sm z-30 md:hidden" @onclick="ToggleMobileMenu"></div>
    }

    <!-- Sidebar Navigation -->
    <nav class="@GetSidebarClass()">
        <!-- Sidebar Header -->
        <div class="@GetSidebarHeaderClass()">
            <div class="@GetSidebarTitleClass()">
                Chronon Tracker
            </div>
            <button @onclick="ToggleSidebar" class="hidden md:block p-1.5 rounded-md hover:bg-accent text-muted-foreground hover:text-accent-foreground transition-colors focus:outline-none" title="@(_isCollapsed ? "Expand Sidebar" : "Collapse Sidebar")">
                @if (_isCollapsed)
                {
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6"><rect width="18" height="18" x="3" y="3" rx="2"/><path d="M9 3v18"/><path d="m14 15 3-3-3-3"/></svg>
                }
                else
                {
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6"><rect width="18" height="18" x="3" y="3" rx="2"/><path d="M9 3v18"/><path d="m16 15-3-3 3-3"/></svg>
                }
            </button>
        </div>

        <!-- Navigation Links -->
        <div class="flex flex-col py-3 space-y-1">
            <NavLink class="@GetNavLinkClass()" href="" Match="NavLinkMatch.All" ActiveClass="bg-accent text-accent-foreground font-semibold shadow-sm" title="@(_isCollapsed ? "Dashboard" : "")" @onclick="CloseMobileMenu">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6 shrink-0 lucide lucide-home"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                <span class="@GetNavLinkTextClass()">
                    Dashboard
                </span>
            </NavLink>
            <NavLink class="@GetNavLinkClass()" href="calendar" ActiveClass="bg-accent text-accent-foreground font-semibold shadow-sm" title="@(_isCollapsed ? "Calendar" : "")" @onclick="CloseMobileMenu">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6 shrink-0 lucide lucide-calendar"><path d="M8 2v4"/><path d="M16 2v4"/><rect width="18" height="18" x="3" y="4" rx="2"/><path d="M3 10h18"/></svg>
                <span class="@GetNavLinkTextClass()">
                    Calendar
                </span>
            </NavLink>
            <NavLink class="@GetNavLinkClass()" href="attendance" ActiveClass="bg-accent text-accent-foreground font-semibold shadow-sm" title="@(_isCollapsed ? "Attendance" : "")" @onclick="CloseMobileMenu">
