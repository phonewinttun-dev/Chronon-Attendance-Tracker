@inherits LayoutComponentBase

<div class="flex min-h-screen bg-background text-foreground">
    <!-- Sidebar -->
    <nav class="w-64 bg-card border-r border-border flex flex-col shrink-0">
        <div class="p-6 text-xl font-bold text-foreground border-b border-border tracking-tight">
            Chronon Tracker
        </div>
        <div class="flex flex-col py-3 space-y-1">
            <NavLink class="px-4 py-2 mx-3 rounded-md text-sm font-medium transition-all text-muted-foreground hover:bg-accent hover:text-accent-foreground flex items-center gap-2" href="" Match="NavLinkMatch.All" ActiveClass="bg-accent text-accent-foreground font-semibold shadow-sm">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 shrink-0 lucide lucide-home"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                Dashboard
            </NavLink>
            <NavLink class="px-4 py-2 mx-3 rounded-md text-sm font-medium transition-all text-muted-foreground hover:bg-accent hover:text-accent-foreground flex items-center gap-2" href="calendar" ActiveClass="bg-accent text-accent-foreground font-semibold shadow-sm">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 shrink-0 lucide lucide-calendar"><path d="M8 2v4"/><path d="M16 2v4"/><rect width="18" height="18" x="3" y="4" rx="2"/><path d="M3 10h18"/></svg>
                Calendar
            </NavLink>
            <NavLink class="px-4 py-2 mx-3 rounded-md text-sm font-medium transition-all text-muted-foreground hover:bg-accent hover:text-accent-foreground flex items-center gap-2" href="semesters" ActiveClass="bg-accent text-accent-foreground font-semibold shadow-sm">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 shrink-0 lucide lucide-graduation-cap"><path d="M21.42 10.922a1 1 0 0 0-.019-1.838L12.83 5.18a2 2 0 0 0-1.66 0L2.6 9.08a1 1 0 0 0 0 1.832l8.57 3.908a2 2 0 0 0 1.66 0z"/><path d="M6 12v5c0 2 2 3 6 3s6-1 6-3v-5"/><path d="M21.5 12v6"/></svg>
                Semesters
            </NavLink>
            <NavLink class="px-4 py-2 mx-3 rounded-md text-sm font-medium transition-all text-muted-foreground hover:bg-accent hover:text-accent-foreground flex items-center gap-2" href="modules" ActiveClass="bg-accent text-accent-foreground font-semibold shadow-sm">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 shrink-0 lucide lucide-book-open"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
                Modules
            </NavLink>
            <NavLink class="px-4 py-2 mx-3 rounded-md text-sm font-medium transition-all text-muted-foreground hover:bg-accent hover:text-accent-foreground flex items-center gap-2" href="holidays" ActiveClass="bg-accent text-accent-foreground font-semibold shadow-sm">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 shrink-0 lucide lucide-bed"><path d="M2 4v16"/><path d="M2 8h18a2 2 0 0 1 2 2v10"/><path d="M2 17h20"/><path d="M6 8v9"/></svg>
                Holidays
            </NavLink>
            <NavLink class="px-4 py-2 mx-3 rounded-md text-sm font-medium transition-all text-muted-foreground hover:bg-accent hover:text-accent-foreground flex items-center gap-2" href="sessions" ActiveClass="bg-accent text-accent-foreground font-semibold shadow-sm">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 shrink-0 lucide lucide-clock"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                Sessions
            </NavLink>
        </div>
    </nav>

    <!-- Main Content -->
    <main class="flex-1 p-8 overflow-y-auto max-w-7xl mx-auto w-full">
        @Body
    </main>
</div>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload text-primary ml-2 hover:underline">Reload</a>
    <a class="dismiss cursor-pointer float-right mr-2 hover:text-destructive">🗙</a>
</div>
